@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Admin Panel</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <style>
            body {
                background: #f5f6fa;
            }

            /* Sidebar */
            .admin-sidebar {
                width: 240px;
                height: 100vh;
                position: fixed;
                top: 0;
                left: 0;
                background: #1f2937;
                padding-top: 70px; /* navbar yüksekliği */
            }

                .admin-sidebar a {
                    display: block;
                    padding: 12px 20px;
                    color: #d1d5db;
                    text-decoration: none;
                    font-size: 15px;
                }

                    .admin-sidebar a:hover {
                        background: #374151;
                        color: #fff;
                    }

            /* İçerik alanı */
            .admin-content {
                margin-left: 240px;
                padding: 30px;
                margin-top: 70px; /* navbar yüksekliği kadar boşluk EKLENDİ */
            }

            .navbar-brand {
                font-weight: bold;
            }
    </style>
</head>

<body>

    <!-- Navbar -->
    <nav class="navbar navbar-dark bg-dark fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <i class="fa-solid fa-gauge"></i> Admin Panel
            </a>
        </div>
    </nav>

    <!-- Sidebar -->
    <div class="admin-sidebar">
        <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
            <i class="fa-solid fa-chart-line"></i> Dashboard
        </a>

        <a asp-area="Admin" asp-controller="Project" asp-action="Index">
            <i class="fa-solid fa-diagram-project"></i> Projeler
        </a>

        <a asp-area="Admin" asp-controller="Experience" asp-action="Index">
            <i class="fa-solid fa-briefcase"></i> Deneyimler
        </a>

        <a asp-area="Admin" asp-controller="Media" asp-action="Upload">
            <i class="fa-solid fa-upload"></i> Medya Yükle
        </a>

        <a asp-area="Admin" asp-controller="Certificate" asp-action="Index">
            <i class="fa-solid fa-certificate"></i> Sertifikalar
        </a>

        <a asp-area="Admin" asp-controller="Skill" asp-action="Index">
            <i class="fa-solid fa-code"></i> Yetenekler
        </a>
    </div>

    <!-- Content -->
    <div class="admin-content">
        @RenderBody()
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
