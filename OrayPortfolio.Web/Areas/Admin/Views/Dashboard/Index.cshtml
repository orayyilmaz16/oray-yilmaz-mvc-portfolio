@using OrayPortfolio.Application.DTOs.Dashboard
@model DashboardViewModel

<style>
    /* Dashboard Özel Stilleri */
    .ap-dashboard-header {
        color: var(--text);
        font-weight: 700;
        margin-bottom: 1.5rem;
        font-size: 1.5rem;
        letter-spacing: -0.5px;
    }

    /* ÜST BİLGİ ÇUBUĞU */
    .ap-top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 16px 24px;
        margin-bottom: 24px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        animation: ap-fade-down 0.5s var(--ease) forwards;
        flex-wrap: wrap;
        gap: 15px;
    }

    .ap-top-bar-left {
        display: flex;
        align-items: center;
        gap: 24px;
    }

        .ap-top-bar-left h2 {
            margin: 0;
            font-size: 1.4rem;
            color: var(--text);
            font-weight: 800;
            letter-spacing: -0.5px;
        }

        .ap-top-bar-left p {
            margin: 6px 0 0 0;
            color: var(--text-dim);
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            flex-wrap: wrap;
            gap: 8px;
        }

    /* YENİLE BUTONU TASARIMI */
    .ap-refresh-btn {
        background: rgba(109, 94, 249, 0.1);
        color: var(--brand-light);
        border: 1px solid rgba(109, 94, 249, 0.2);
        padding: 8px 16px;
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
    }

        .ap-refresh-btn:hover:not(:disabled) {
            background: var(--brand);
            color: #fff;
            box-shadow: 0 4px 15px rgba(109, 94, 249, 0.4);
            transform: translateY(-2px);
        }

        .ap-refresh-btn:disabled {
            cursor: not-allowed;
            opacity: 0.7;
        }

    .spin-anim {
        animation: spin 0.8s linear infinite;
    }

    
    .ap-live-clock {
        text-align: right;
    }

        .ap-live-clock .time {
            font-size: 1.6rem;
            font-weight: 800;
            color: var(--brand-light);
            font-family: 'JetBrains Mono', monospace;
            letter-spacing: 1px;
            line-height: 1.2;
        }

        .ap-live-clock .date {
            font-size: 0.85rem;
            color: var(--text-dim);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

    /* VERİ ALANI YÜKLENİYOR (BLUR) OVERLAY TASARIMI */
    .ap-data-wrapper {
        position: relative;
        min-height: 300px;
    }

    .ap-loader-overlay {
        position: absolute;
        top: -10px;
        left: -10px;
        right: -10px;
        bottom: -10px;
        background: rgba(23, 28, 40, 0.65);
        backdrop-filter: blur(6px);
        z-index: 100;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s var(--ease);
        border-radius: 20px;
    }

        .ap-loader-overlay.is-active {
            opacity: 1;
            pointer-events: all;
        }

    .ap-spinner {
        width: 50px;
        height: 50px;
        border: 4px solid rgba(109, 94, 249, 0.2);
        border-top-color: var(--brand);
        border-radius: 50%;
        animation: spin 1s linear infinite;
        margin-bottom: 12px;
    }

    .ap-loader-text {
        color: var(--text);
        font-weight: 600;
        font-size: 1rem;
        letter-spacing: 1px;
        animation: pulseText 1.5s infinite;
    }


    /* Kart Tasarımları */
    .ap-card {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 20px;
        transition: transform 0.3s var(--ease), box-shadow 0.3s var(--ease), border-color 0.3s var(--ease);
        height: 100%;
        opacity: 0;
        animation: ap-fade-up 0.5s var(--ease) forwards;
        display: flex;
        flex-direction: column;
    }

        .ap-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 24px -10px rgba(0, 0, 0, 0.5);
            border-color: var(--brand-light);
        }

    .ap-stat-card {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .ap-stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        flex-shrink: 0;
    }

        /* İkon Renkleri */
        .ap-stat-icon.visitor-today {
            background: rgba(45, 212, 191, 0.15);
            color: #2dd4bf;
        }

        .ap-stat-icon.visitor-total {
            background: rgba(109, 94, 249, 0.15);
            color: #6d5ef9;
        }

        .ap-stat-icon.project {
            background: rgba(255, 193, 7, 0.15);
            color: #ffc107;
        }

        .ap-stat-icon.experience {
            background: rgba(251, 69, 112, 0.15);
            color: #fb4570;
        }

        .ap-stat-icon.certificate {
            background: rgba(13, 110, 253, 0.15);
            color: #0d6efd;
        }

        .ap-stat-icon.skill {
            background: rgba(255, 136, 0, 0.15);
            color: #ff8800;
        }

        .ap-stat-icon.volunteer {
            background: rgba(32, 201, 151, 0.15);
            color: #20c997;
        }

        .ap-stat-icon.reference {
            background: rgba(111, 66, 193, 0.15);
            color: #6f42c1;
        }

    .ap-stat-info h3 {
        color: var(--text);
        font-size: 1.75rem;
        font-weight: 800;
        margin: 0;
        font-family: 'JetBrains Mono', monospace;
        transition: color 0.4s ease, transform 0.2s ease;
        display: inline-block;
    }

    .ap-stat-info p {
        color: var(--text-dim);
        font-size: 0.85rem;
        font-weight: 600;
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Başlıklar ve Listeler */
    .ap-card-title {
        color: var(--text);
        font-size: 1.1rem;
        font-weight: 600;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
    }

        .ap-card-title i {
            color: var(--brand-light);
        }

    .ap-list-group {
        border-radius: 12px;
        overflow-y: auto;
        border: 1px solid var(--line);
        flex: 1;
        min-height: 120px;
        max-height: 250px;
    }

        /* İnce Kaydırma Çubuğu (Scrollbar) */
        .ap-list-group::-webkit-scrollbar {
            width: 6px;
        }

        .ap-list-group::-webkit-scrollbar-track {
            background: transparent;
        }

        .ap-list-group::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
        }

            .ap-list-group::-webkit-scrollbar-thumb:hover {
                background: rgba(255, 255, 255, 0.2);
            }

    .ap-list-item {
        background: transparent;
        border: none;
        border-bottom: 1px solid var(--line);
        color: var(--text-dim);
        padding: 12px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        transition: background 0.2s, color 0.2s;
    }

        .ap-list-item:last-child {
            border-bottom: none;
        }

        .ap-list-item:hover {
            background: var(--surface-hover);
            color: var(--text);
        }

        .ap-list-item i {
            color: var(--brand);
            font-size: 0.85rem;
        }

    /* Profil Tamamlanma Barı */
    .ap-progress-wrapper {
        background: rgba(0,0,0,0.2);
        border-radius: 99px;
        height: 10px;
        overflow: hidden;
        border: 1px solid var(--line);
    }

    .ap-progress-bar {
        background: linear-gradient(90deg, var(--brand), var(--accent));
        height: 100%;
        border-radius: 99px;
        box-shadow: 0 0 10px rgba(45, 212, 191, 0.4);
        transition: width 1.5s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .ap-progress-text {
        color: var(--text-dim);
        font-weight: 600;
        font-size: 0.9rem;
        margin-top: 8px;
        text-align: right;
    }

    /* 📌 YENİ: KAYIT GEÇMİŞİ MODERN BAŞLIK KARTI */
    .ap-history-header-card {
        background: linear-gradient(135deg, rgba(23, 28, 40, 0.8), rgba(23, 28, 40, 0.4));
        border: 1px solid var(--line);
        border-left: 4px solid var(--brand);
        border-radius: 16px;
        padding: 20px 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 10px 30px -10px rgba(0,0,0,0.3);
        backdrop-filter: blur(10px);
        flex-wrap: wrap;
        gap: 15px;
    }

        .ap-history-header-card .header-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .ap-history-header-card .icon-box {
            width: 48px;
            height: 48px;
            background: rgba(109, 94, 249, 0.15);
            color: var(--brand-light);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
        }

        .ap-history-header-card .title {
            color: var(--text);
            font-size: 1.3rem;
            font-weight: 700;
            margin: 0 0 4px 0;
            letter-spacing: -0.3px;
        }

        .ap-history-header-card .subtitle {
            color: var(--text-dim);
            font-size: 0.85rem;
            margin: 0;
        }

        .ap-history-header-card .header-right {
            text-align: right;
        }

        .ap-history-header-card .sync-label {
            font-size: 0.75rem;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
            margin-bottom: 6px;
            display: block;
        }

        .ap-history-header-card .sync-datetime {
            display: flex;
            gap: 8px;
            align-items: center;
            justify-content: flex-end;
            flex-wrap: wrap;
        }

        .ap-history-header-card .date-badge,
        .ap-history-header-card .time-badge {
            background: var(--surface);
            border: 1px solid var(--line);
            color: var(--text);
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 0.85rem;
            font-family: 'JetBrains Mono', monospace;
            display: flex;
            align-items: center;
            gap: 6px;
        }

    .text-accent {
        color: var(--accent) !important;
    }

    .text-warning {
        color: #ffc107 !important;
    }

    .delay-1 {
        animation-delay: 0.1s;
    }

    .delay-2 {
        animation-delay: 0.2s;
    }

    .delay-3 {
        animation-delay: 0.3s;
    }
</style>

<div class="ap-top-bar">
    <div class="ap-top-bar-left">
        <div>
            <h2>Genel Bakış</h2>
            <p>
                <i class="fa-solid fa-right-to-bracket" style="color: var(--accent);"></i>
                Giriş: <strong id="last-login-time" style="color: var(--text);">...</strong>
                <span class="badge" style="background: rgba(45, 212, 191, 0.1); color: var(--accent); font-weight: 600; border: 1px solid rgba(45, 212, 191, 0.2); padding: 5px 8px;" id="login-minutes-ago">...</span>

                <span style="color: var(--line); margin: 0 4px;">|</span>

                <i class="fa-solid fa-bolt" style="color: #ffc107;"></i>
                Son Güncelleme: <strong id="last-update-time" style="color: var(--text);">Şimdi</strong>
                <span class="badge" style="background: rgba(255, 193, 7, 0.1); color: #ffc107; font-weight: 600; border: 1px solid rgba(255, 193, 7, 0.2); padding: 5px 8px;" id="update-minutes-ago">Az önce</span>
            </p>
        </div>
        <button id="btn-refresh-dashboard" class="ap-refresh-btn" title="Sayfayı yenilemeden güncel verileri çek">
            <i class="fa-solid fa-arrows-rotate"></i> <span>Yenile</span>
        </button>
    </div>
    <div class="ap-live-clock">
        <div class="time" id="live-time">00:00:00</div>
        <div class="date" id="live-date">...</div>
    </div>
</div>

<div class="ap-data-wrapper">

    <div id="dashboard-loader" class="ap-loader-overlay">
        <div class="ap-spinner"></div>
        <div class="ap-loader-text">Veriler Çekiliyor...</div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="ap-card delay-1" style="border-color: rgba(45, 212, 191, 0.3); background: linear-gradient(145deg, var(--surface), rgba(45, 212, 191, 0.03));">
                <div class="ap-stat-card"><div class="ap-stat-icon visitor-today"><i class="fa-solid fa-eye"></i></div><div class="ap-stat-info"><h3 id="cnt-today">0</h3><p>Bugün Ziyaret</p></div></div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="ap-card delay-1" style="border-color: rgba(109, 94, 249, 0.3); background: linear-gradient(145deg, var(--surface), rgba(109, 94, 249, 0.03));">
                <div class="ap-stat-card"><div class="ap-stat-icon visitor-total"><i class="fa-solid fa-chart-line"></i></div><div class="ap-stat-info"><h3 id="cnt-total">0</h3><p>Toplam Ziyaret</p></div></div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6"><div class="ap-card delay-1"><div class="ap-stat-card"><div class="ap-stat-icon project"><i class="fa-solid fa-diagram-project"></i></div><div class="ap-stat-info"><h3 id="cnt-project">0</h3><p>Projeler</p></div></div></div></div>
        <div class="col-xl-3 col-md-6"><div class="ap-card delay-1"><div class="ap-stat-card"><div class="ap-stat-icon skill"><i class="fa-solid fa-code"></i></div><div class="ap-stat-info"><h3 id="cnt-skill">0</h3><p>Yetenekler</p></div></div></div></div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6"><div class="ap-card delay-2"><div class="ap-stat-card"><div class="ap-stat-icon experience"><i class="fa-solid fa-briefcase"></i></div><div class="ap-stat-info"><h3 id="cnt-experience">0</h3><p>Deneyimler</p></div></div></div></div>
        <div class="col-xl-3 col-md-6"><div class="ap-card delay-2"><div class="ap-stat-card"><div class="ap-stat-icon education"><i class="fa-solid fa-graduation-cap"></i></div><div class="ap-stat-info"><h3 id="cnt-education">0</h3><p>Eğitimler</p></div></div></div></div>
        <div class="col-xl-3 col-md-6"><div class="ap-card delay-2"><div class="ap-stat-card"><div class="ap-stat-icon certificate"><i class="fa-solid fa-certificate"></i></div><div class="ap-stat-info"><h3 id="cnt-certificate">0</h3><p>Sertifikalar</p></div></div></div></div>
        <div class="col-xl-3 col-md-6"><div class="ap-card delay-2"><div class="ap-stat-card"><div class="ap-stat-icon reference"><i class="fa-solid fa-user-tie"></i></div><div class="ap-stat-info"><h3 id="cnt-reference">0</h3><p>Referanslar</p></div></div></div></div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-8 col-lg-7">
            <div class="ap-card delay-3">
                <h5 class="ap-card-title"><i class="fa-solid fa-chart-area"></i> Son 7 Günlük Ziyaretçi Trafiği</h5>
                <div style="position: relative; height:300px; width:100%">
                    <canvas id="trafficChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-lg-5">
            <div class="row g-4">
                <div class="col-12">
                    <div class="ap-card delay-3">
                        <h5 class="ap-card-title"><i class="fa-solid fa-chart-bar"></i> İçerik Dağılımı</h5>
                        <div style="position: relative; height:200px; width:100%">
                            <canvas id="statsChart"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-12">
                    <div class="ap-card delay-3">
                        <h5 class="ap-card-title"><i class="fa-solid fa-user-check"></i> Profil Durumu</h5>
                        <div class="ap-progress-wrapper mt-4">
                            <div class="ap-progress-bar" id="pb-completion" style="width:0%" data-target="@Model.ProfileCompletion"></div>
                        </div>
                        <div class="ap-progress-text" id="cnt-completion">@Model.ProfileCompletion% Tamamlandı</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4 delay-3">
        <div class="col-12">
            <div class="ap-history-header-card">
                <div class="header-left">
                    <div class="icon-box">
                        <i class="fa-solid fa-clock-rotate-left"></i>
                    </div>
                    <div>
                        <h4 class="title">Kayıt Geçmişi</h4>
                        <p class="subtitle">Sisteme en son eklenen verilerin listesi</p>
                    </div>
                </div>
                <div class="header-right">
                    <span class="sync-label">Liste Senkronizasyonu</span>
                    <div class="sync-datetime">
                        <span class="date-badge"><i class="fa-regular fa-calendar-check text-accent"></i> <span id="history-sync-date">...</span></span>
                        <span class="time-badge"><i class="fa-regular fa-clock text-warning"></i> <span id="history-sync-time">...</span></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 pb-5">
        <div class="col-xl-3 col-md-6">
            <div class="ap-card delay-3" style="padding: 15px;">
                <h5 class="ap-card-title" style="font-size: 1rem;"><i class="fa-solid fa-diagram-project" style="color: #ffc107;"></i> Projeler</h5>
                <div class="ap-list-group" id="list-project">
                    @if (Model.LastProjects?.Any() == true)
                    {
                        foreach (var p in Model.LastProjects)
                        {
                            <div class="ap-list-item"><i class="fa-solid fa-circle-check"></i><span>@p.Title</span></div>
                        }
                    }
                    else
                    {

                        <div class="ap-list-item" style="justify-content:center;">Kayıt yok.</div>
                    }
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="ap-card delay-3" style="padding: 15px;">
                <h5 class="ap-card-title" style="font-size: 1rem;"><i class="fa-solid fa-briefcase" style="color: var(--danger);"></i> Deneyimler</h5>
                <div class="ap-list-group" id="list-experience">
                    @if (Model.LastExperiences?.Any() == true)
                    {
                        foreach (var e in Model.LastExperiences)
                        {
                            <div class="ap-list-item"><i class="fa-solid fa-circle-check"></i><span>@e.Position</span></div>
                        }
                    }
                    else
                    {

                        <div class="ap-list-item" style="justify-content:center;">Kayıt yok.</div>
                    }
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="ap-card delay-3" style="padding: 15px;">
                <h5 class="ap-card-title" style="font-size: 1rem;"><i class="fa-solid fa-graduation-cap" style="color: var(--accent);"></i> Eğitimler</h5>
                <div class="ap-list-group" id="list-education">
                    @if (Model.LastEducations?.Any() == true)
                    {
                        foreach (var e in Model.LastEducations)
                        {
                            <div class="ap-list-item"><i class="fa-solid fa-circle-check"></i><span>@e.School</span></div>
                        }
                    }
                    else
                    {

                        <div class="ap-list-item" style="justify-content:center;">Kayıt yok.</div>
                    }
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="ap-card delay-3" style="padding: 15px;">
                <h5 class="ap-card-title" style="font-size: 1rem;"><i class="fa-solid fa-code" style="color: #ff8800;"></i> Yetenekler</h5>
                <div class="ap-list-group" id="list-skill">
                    @if (Model.LastSkills?.Any() == true)
                    {
                        foreach (var s in Model.LastSkills)
                        {
                            <div class="ap-list-item"><i class="fa-solid fa-circle-check"></i><span>@s.Name</span></div>
                        }
                    }
                    else
                    {

                        <div class="ap-list-item" style="justify-content:center;">Kayıt yok.</div>
                    }
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-md-6">
            <div class="ap-card delay-3" style="padding: 15px;">
                <h5 class="ap-card-title" style="font-size: 1rem;"><i class="fa-solid fa-certificate" style="color: #0d6efd;"></i> Sertifikalar</h5>
                <div class="ap-list-group" id="list-certificate">
                    @if (Model.LastCertificates?.Any() == true)
                    {
                        foreach (var c in Model.LastCertificates)
                        {
                            <div class="ap-list-item"><i class="fa-solid fa-circle-check"></i><span>@c.Title</span></div>
                        }
                    }
                    else
                    {

                        <div class="ap-list-item" style="justify-content:center;">Kayıt yok.</div>
                    }
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-md-6">
            <div class="ap-card delay-3" style="padding: 15px;">
                <h5 class="ap-card-title" style="font-size: 1rem;"><i class="fa-solid fa-handshake-angle" style="color: #20c997;"></i> Gönüllü Çalışmalar</h5>
                <div class="ap-list-group" id="list-volunteer">
                    @if (Model.LastVolunteerWorks?.Any() == true)
                    {
                        foreach (var v in Model.LastVolunteerWorks)
                        {
                            <div class="ap-list-item"><i class="fa-solid fa-circle-check"></i><span>@v.Organization</span></div>
                        }
                    }
                    else
                    {

                        <div class="ap-list-item" style="justify-content:center;">Kayıt yok.</div>
                    }
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-md-6">
            <div class="ap-card delay-3" style="padding: 15px;">
                <h5 class="ap-card-title" style="font-size: 1rem;"><i class="fa-solid fa-user-tie" style="color: #6f42c1;"></i> Referanslar</h5>
                <div class="ap-list-group" id="list-reference">
                    @if (Model.LastReferences?.Any() == true)
                    {
                        foreach (var r in Model.LastReferences)
                        {
                            <div class="ap-list-item"><i class="fa-solid fa-circle-check"></i><span>@r.FullName</span></div>
                        }
                    }
                    else
                    {

                        <div class="ap-list-item" style="justify-content:center;">Kayıt yok.</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {

    // --- ZAMAN HESAPLAMA METODU ---
    function getRelativeTimeText(pastDate) {
    const diffMs = new Date() - pastDate;
    const diffMins = Math.floor(diffMs / 60000);
    const diffHours = Math.floor(diffMins / 60);

    if (diffMins === 0) return "Az önce";
    if (diffMins < 60) return diffMins + " dk önce";
    return diffHours + " saat " + (diffMins % 60) + " dk önce";
    }

    // --- CANLI SAAT ---
    function updateLiveClock() {
    const now = new Date();
    document.getElementById('live-time').innerText = now.toLocaleTimeString('tr-TR', { hour12: false });
    document.getElementById('live-date').innerText = now.toLocaleDateString('tr-TR', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
    }
    setInterval(updateLiveClock, 1000);
    updateLiveClock();

    // --- LİSTE SENKRONİZASYON ZAMANI ---
    function updateHistorySyncTime() {
    const now = new Date();
    const dateStr = now.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' });
    const timeStr = now.toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });

    const historyDateEl = document.getElementById('history-sync-date');
    const historyTimeEl = document.getElementById('history-sync-time');

    if (historyDateEl) historyDateEl.innerText = dateStr;
    if (historyTimeEl) historyTimeEl.innerText = timeStr;
    }
    // Sayfa açıldığında ilk senkronizasyon zamanını yazdır
    updateHistorySyncTime();

    // --- GİRİŞ VE GÜNCELLEME ZAMANI ---
    let loginTimeIso = sessionStorage.getItem('admin_login_time');
    if (!loginTimeIso) {
    loginTimeIso = new Date().toISOString();
    sessionStorage.setItem('admin_login_time', loginTimeIso);
    }
    const loginTime = new Date(loginTimeIso);
    document.getElementById('last-login-time').innerText = loginTime.toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit' });

    let updateTime = new Date();
    document.getElementById('last-update-time').innerText = updateTime.toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit' });

    function refreshTimeBadges() {
    document.getElementById('login-minutes-ago').innerText = getRelativeTimeText(loginTime);
    document.getElementById('update-minutes-ago').innerText = getRelativeTimeText(updateTime);
    }
    setInterval(refreshTimeBadges, 60000);
    refreshTimeBadges();

    // --- SAYI SAYMA ANİMASYONU ---
    const animateCountUp = (id, endValue, duration = 1000) => {
    const el = document.getElementById(id);
    if(!el) return;

    const startValue = parseInt(el.innerText) || 0;
    if (startValue === endValue) return;

    el.style.color = 'var(--brand)';
    el.style.transform = 'scale(1.15)';

    let startTime = null;
    const step = (currentTime) => {
    if (!startTime) startTime = currentTime;
    const progress = Math.min((currentTime - startTime) / duration, 1);

    const easeOutQuad = progress * (2 - progress);
    const currentVal = Math.floor(startValue + (endValue - startValue) * easeOutQuad);

    el.innerText = currentVal;

    if (progress < 1) requestAnimationFrame(step);
    else {
    el.innerText = endValue;
    setTimeout(() => { el.style.color = 'var(--text)'; el.style.transform = 'scale(1)'; }, 300);
    }
    };
    requestAnimationFrame(step);
    };

    // İLK YÜKLEME
    setTimeout(() => {
    animateCountUp('cnt-today', @Model.TodayVisitors, 1200);
    animateCountUp('cnt-total', @Model.TotalVisitors, 1500);
    animateCountUp('cnt-project', @Model.ProjectCount, 1000);
    animateCountUp('cnt-skill', @Model.SkillCount, 1000);
    animateCountUp('cnt-experience', @Model.ExperienceCount, 1000);
    animateCountUp('cnt-education', @Model.EducationCount, 1000);
    animateCountUp('cnt-certificate', @Model.CertificateCount, 1000);
    animateCountUp('cnt-reference', @Model.ReferenceCount, 1000);

    const progressBar = document.getElementById('pb-completion');
    if(progressBar) progressBar.style.width = progressBar.getAttribute('data-target') + '%';
    }, 100);

    const style = getComputedStyle(document.body);
    const colorBrand = style.getPropertyValue('--brand').trim() || '#6d5ef9';
    const colorAccent = style.getPropertyValue('--accent').trim() || '#2dd4bf';
    const colorDanger = style.getPropertyValue('--danger').trim() || '#fb4570';
    const colorTextDim = style.getPropertyValue('--text-dim').trim() || '#8b93a7';
    const colorLine = style.getPropertyValue('--line').trim() || '#242b3a';

    const colorSkill = '#ff8800';
    const colorCert = '#0d6efd';
    const colorVol = '#20c997';
    const colorRef = '#6f42c1';

    const commonTooltip = { backgroundColor: '#171c28', titleColor: '#eef1f6', bodyColor: '#8b93a7', borderColor: '#242b3a', borderWidth: 1, padding: 10, cornerRadius: 8 };

    let chartTrafficInstance = null;
    let chartStatsInstance = null;

    // --- GRAFİKLER ---
    const trafficCtx = document.getElementById('trafficChart');
    if(trafficCtx) {
    const ctx = trafficCtx.getContext('2d');
    let gradientFill = ctx.createLinearGradient(0, 0, 0, 300);
    gradientFill.addColorStop(0, 'rgba(45, 212, 191, 0.4)');
    gradientFill.addColorStop(1, 'rgba(45, 212, 191, 0.0)');

    chartTrafficInstance = new Chart(ctx, {
    type: 'line',
    data: { labels: @Html.Raw(Json.Serialize(Model.WeeklyVisitorDates)), datasets: [{ label: 'Ziyaretçi', data: @Html.Raw(Json.Serialize(Model.WeeklyVisitorCounts)), borderColor: colorAccent, backgroundColor: gradientFill, borderWidth: 3, pointBackgroundColor: '#fff', pointBorderColor: colorAccent, pointBorderWidth: 2, pointRadius: 4, pointHoverRadius: 6, fill: true, tension: 0.4 }] },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false }, tooltip: commonTooltip }, scales: { y: { beginAtZero: true, grid: { color: colorLine, drawBorder: false }, ticks: { color: colorTextDim, stepSize: 1 } }, x: { grid: { display: false, drawBorder: false }, ticks: { color: colorTextDim } } } }
    });
    }

    const statsCtx = document.getElementById('statsChart');
    if(statsCtx) {
    chartStatsInstance = new Chart(statsCtx.getContext('2d'), {
    type: 'bar',
    data: {
    labels: ['Proje', 'Deneyim', 'Eğitim', 'Yetenek', 'Sertifika', 'Gönüllü', 'Referans'],
    datasets: [{
    data: [@Model.ProjectCount, @Model.ExperienceCount, @Model.EducationCount, @Model.SkillCount, @Model.CertificateCount, @Model.VolunteerWorkCount, @Model.ReferenceCount],
    backgroundColor: ['#ffc107', colorDanger, colorAccent, colorSkill, colorCert, colorVol, colorRef],
    borderRadius: 6, borderWidth: 0, barPercentage: 0.5
    }]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false }, tooltip: commonTooltip }, scales: { y: { beginAtZero: true, grid: { color: colorLine, drawBorder: false }, ticks: { color: colorTextDim, stepSize: 1 } }, x: { grid: { display: false, drawBorder: false }, ticks: { color: colorTextDim, font: { size: 10 } } } } }
    });
    }

    // 📌 AJAX LİSTE OLUŞTURUCU (XSS Korumalı)
    function buildListHtml(items) {
        if (!items || items.length === 0) return `<div class="ap-list-item" style="justify-content:center;">Kayıt yok.</div>`;
        // 📌 EKSİK OLAN YER: item.text değerini escapeHtml içine aldık!
        return items.map(item => `<div class="ap-list-item"><i class="fa-solid fa-circle-check"></i><span>${escapeHtml(item.text)}</span></div>`).join('');
    }

    function escapeHtml(text) {
    const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
    return text.replace(/[&<>"']/g, function(m) { return map[m]; });
    }

    // --- AJAX REFRESH MANTIĞI & EKRAN BLUR YÜKLEMESİ ---
    const refreshBtn = document.getElementById('btn-refresh-dashboard');
    const loaderOverlay = document.getElementById('dashboard-loader');

    if(refreshBtn) {
    refreshBtn.addEventListener('click', async function() {
    const icon = this.querySelector('i');
    const textSpan = this.querySelector('span');

    this.disabled = true;
    icon.classList.add('spin-anim');
    textSpan.innerText = 'Yükleniyor...';
    loaderOverlay.classList.add('is-active');

    try {
    const minWaitPromise = new Promise(resolve => setTimeout(resolve, 600));
    const fetchPromise = fetch('/Admin/Dashboard/GetDashboardDataJson');

    const [response] = await Promise.all([fetchPromise, minWaitPromise]);
    const data = await response.json();

    updateTime = new Date();
    document.getElementById('last-update-time').innerText = updateTime.toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit' });
    refreshTimeBadges();

    // 📌 Yeni eklediğimiz liste güncelleme tarihini de yenile
    updateHistorySyncTime();

    animateCountUp('cnt-today', data.todayVisitors, 800);
    animateCountUp('cnt-total', data.totalVisitors, 800);
    animateCountUp('cnt-project', data.projectCount, 800);
    animateCountUp('cnt-skill', data.skillCount, 800);
    animateCountUp('cnt-experience', data.experienceCount, 800);
    animateCountUp('cnt-education', data.educationCount, 800);
    animateCountUp('cnt-certificate', data.certificateCount, 800);
    animateCountUp('cnt-reference', data.referenceCount, 800);

    const pb = document.getElementById('pb-completion');
    const pText = document.getElementById('cnt-completion');
    if(pb) pb.style.width = data.profileCompletion + '%';
    if(pText) pText.innerText = data.profileCompletion + '% Tamamlandı';

    if(chartTrafficInstance) {
    chartTrafficInstance.data.labels = data.weeklyVisitorDates;
    chartTrafficInstance.data.datasets[0].data = data.weeklyVisitorCounts;
    chartTrafficInstance.update();
    }

    if(chartStatsInstance) {
    chartStatsInstance.data.datasets[0].data = [data.projectCount, data.experienceCount, data.educationCount, data.skillCount, data.certificateCount, data.volunteerWorkCount, data.referenceCount];
    chartStatsInstance.update();
    }

    document.getElementById('list-project').innerHTML = buildListHtml(data.lastProjects);
    document.getElementById('list-experience').innerHTML = buildListHtml(data.lastExperiences);
    document.getElementById('list-education').innerHTML = buildListHtml(data.lastEducations);
    document.getElementById('list-skill').innerHTML = buildListHtml(data.lastSkills);
    document.getElementById('list-certificate').innerHTML = buildListHtml(data.lastCertificates);
    document.getElementById('list-volunteer').innerHTML = buildListHtml(data.lastVolunteerWorks);
    document.getElementById('list-reference').innerHTML = buildListHtml(data.lastReferences);

    if(typeof toastr !== 'undefined') toastr.success('Veriler başarıyla yenilendi!', 'Sistem Güncel');

    } catch (error) {
    console.error("Veri güncellenirken hata oluştu:", error);
    if(typeof toastr !== 'undefined') toastr.error('Sunucuya bağlanılamadı.', 'Bağlantı Hatası');
    } finally {
    this.disabled = false;
    icon.classList.remove('spin-anim');
    textSpan.innerText = 'Yenile';
    loaderOverlay.classList.remove('is-active');
    }
    });
    }
    });
</script>