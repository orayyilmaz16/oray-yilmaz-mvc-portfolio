@model ProfileUpdateDto

<h2 class="mb-4">Profil Bilgileri</h2>

<form method="post" enctype="multipart/form-data">

    <input type="hidden" asp-for="Id" />

    <div class="row">
        <div class="col-md-8">

            <div class="mb-3">
                <label class="form-label">Ad Soyad</label>
                <input class="form-control" asp-for="FullName" />
            </div>

            <div class="mb-3">
                <label class="form-label">Ünvan</label>
                <input class="form-control" asp-for="Title" />
            </div>

            <div class="mb-3">
                <label class="form-label">Kısa Biyografi</label>
                <textarea class="form-control" asp-for="ShortBio" rows="2"></textarea>
            </div>

            <div class="mb-3">
                <label class="form-label">Uzun Biyografi</label>
                <textarea class="form-control" asp-for="LongBio" rows="5"></textarea>
            </div>

            <hr />

            <h4 class="mt-4">İletişim & Sosyal Medya</h4>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input class="form-control" asp-for="Email" />
            </div>

            <div class="mb-3">
                <label class="form-label">Github</label>
                <input class="form-control" asp-for="GithubUrl" />
            </div>

            <div class="mb-3">
                <label class="form-label">LinkedIn</label>
                <input class="form-control" asp-for="LinkedinUrl" />
            </div>

            <div class="mb-3">
                <label class="form-label">Instagram</label>
                <input class="form-control" asp-for="InstagramUrl" />
            </div>

        </div>

        <div class="col-md-4">

            <h5>Profil Fotoğrafı</h5>

            @if (!string.IsNullOrEmpty(Model.ProfileImagePath))
            {
                <img src="@Model.ProfileImagePath" class="img-fluid rounded mb-3" />
            }
            else
            {
                <p class="text-muted">Henüz profil fotoğrafı yüklenmemiş.</p>
            }

            <div class="mb-3">
                <label class="form-label">Yeni Fotoğraf Yükle</label>
                <input type="file" class="form-control" name="ProfileImage" />
            </div>

        </div>
    </div>

    <button class="btn btn-success mt-3">Güncelle</button>
</form>
