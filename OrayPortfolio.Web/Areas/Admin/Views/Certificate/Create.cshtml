@model CertificateCreateDto

<h2>Yeni Sertifika</h2>

<form method="post">

    <div class="mb-3">
        <label>Başlık</label>
        <input class="form-control" asp-for="Title" />
    </div>

    <div class="mb-3">
        <label>Veren Kurum</label>
        <input class="form-control" asp-for="Issuer" />
    </div>

    <div class="mb-3">
        <label>Tarih</label>
        <input type="date" class="form-control" asp-for="Date" />
    </div>

    <button class="btn btn-success">Kaydet</button>
</form>
