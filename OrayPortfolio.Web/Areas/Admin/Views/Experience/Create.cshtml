@model ExperienceCreateDto

<h2>Yeni Deneyim Ekle</h2>

<form method="post">

    <div class="mb-3">
        <label>Şirket</label>
        <input class="form-control" asp-for="Company" />
    </div>

    <div class="mb-3">
        <label>Pozisyon</label>
        <input class="form-control" asp-for="Position" />
    </div>

    <div class="mb-3">
        <label>Açıklama</label>
        <textarea class="form-control" asp-for="Description"></textarea>
    </div>

    <div class="mb-3">
        <label>Başlangıç Tarihi</label>
        <input type="date" class="form-control" asp-for="StartDate" />
    </div>

    <div class="mb-3">
        <label>Bitiş Tarihi</label>
        <input type="date" class="form-control" asp-for="EndDate" />
    </div>

    <div class="form-check mb-3">
        <input class="form-check-input" asp-for="IsCurrent" />
        <label class="form-check-label">Halen Çalışıyorum</label>
    </div>

    <button class="btn btn-success">Kaydet</button>
</form>
