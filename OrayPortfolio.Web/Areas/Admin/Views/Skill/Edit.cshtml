@model SkillUpdateDto

<style>
    /* Input altı hataları tamamen gizle */
    .ap-hidden-validation {
        display: none !important;
    }

    /* Premium kırmızı hata kutusu */
    .ap-error-box {
        background: rgba(255, 0, 0, 0.12);
        border: 1px solid rgba(255, 0, 0, 0.45);
        color: #ff3b3b;
        padding: 14px 18px;
        border-radius: 12px;
        margin-bottom: 20px;
        font-size: 14px;
        line-height: 1.45;
        animation: ap-fade-in 0.25s ease, ap-shake 0.45s ease;
    }

        .ap-error-box ul {
            margin: 0;
            padding-left: 20px;
        }

        .ap-error-box li {
            margin-bottom: 4px;
        }

    /* Ortak Form CSS */
    .ap-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        animation: ap-fade-up 0.4s var(--ease) both;
    }

    .ap-page-title {
        color: var(--text);
        font-weight: 700;
        font-size: 1.5rem;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .ap-btn-back {
        background: var(--surface);
        color: var(--text-dim);
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid var(--line);
        transition: all 0.2s var(--ease);
        text-decoration: none;
    }

        .ap-btn-back:hover {
            background: var(--surface-hover);
            color: var(--text);
            transform: translateX(-4px);
        }

    .ap-form-card {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 32px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
        animation: ap-fade-up 0.5s var(--ease) 0.1s both;
    }

    .ap-form-group {
        margin-bottom: 24px;
    }

    .ap-form-label {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--text-dim);
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 10px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

        .ap-form-label i {
            color: var(--brand-light);
            font-size: 1rem;
        }

    /* Kategori Select Kutusunu da Bu Sınıfa Dahil Ediyoruz */
    .ap-input, .ap-select {
        width: 100%;
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 14px 16px;
        color: var(--text);
        font-size: 0.95rem;
        font-family: inherit;
        transition: all 0.3s var(--ease);
        color-scheme: dark;
        appearance: none; /* Select okunu temizle (Özel ok ekleyeceğiz) */
    }

        .ap-input::placeholder {
            color: rgba(139, 147, 167, 0.4);
        }

        .ap-input:focus, .ap-select:focus {
            outline: none;
            border-color: var(--brand);
            background: rgba(0, 0, 0, 0.35);
            box-shadow: 0 0 0 4px rgba(109, 94, 249, 0.15);
        }

    /* Select için Özel Tasarım Ok İşareti */
    .ap-select-wrapper {
        position: relative;
    }

        .ap-select-wrapper::after {
            content: '\f107'; /* FontAwesome Aşağı Ok */
            font-family: 'Font Awesome 6 Free';
            font-weight: 900;
            position: absolute;
            right: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-dim);
            pointer-events: none;
        }

    .ap-select option {
        background: var(--surface); /* Dark mode menü arka planı */
        color: var(--text);
    }

    /* Edit Sayfasına Özel Buton Rengi */
    .ap-btn-edit-submit {
        background: linear-gradient(135deg, #f59e0b, #fbbf24);
        color: #171c28;
        border: none;
        border-radius: 12px;
        padding: 14px 28px;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: transform 0.2s var(--ease), box-shadow 0.2s var(--ease);
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-top: 10px;
    }

        .ap-btn-edit-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px -6px rgba(245, 158, 11, 0.6);
        }
</style>

<div class="ap-page-header">
    <h2 class="ap-page-title">Yetenek Düzenle</h2>
    <a class="ap-btn-back" href="/Admin/Skill/Index">
        <i class="fa-solid fa-arrow-left"></i> Geri Dön
    </a>
</div>

<div class="ap-form-card">

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="ap-error-box">
            <ul>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <form method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="Id" />

        <div class="row">
            <div class="col-md-6">
                <div class="ap-form-group">
                    <label class="ap-form-label">
                        <i class="fa-solid fa-bolt"></i> Yetenek Adı
                    </label>
                    <input class="ap-input" asp-for="Name" />
                    <span asp-validation-for="Name" class="ap-hidden-validation"></span>
                </div>
            </div>

            <div class="col-md-6">
                <div class="ap-form-group">
                    <label class="ap-form-label">
                        <i class="fa-solid fa-layer-group"></i> Kategori
                    </label>
                    <div class="ap-select-wrapper">
                        <select asp-for="Category" class="ap-select">
                            <option value="">Seçiniz...</option>
                            <option value="Web Geliştirme">Web Geliştirme (Frontend/Backend)</option>
                            <option value="Mobil Geliştirme">Mobil Geliştirme</option>
                            <option value="Veritabanı Sistemleri">Veritabanı Sistemleri</option>
                            <option value="Yapay Zeka & Veri Bilimi">Yapay Zeka & Veri Bilimi</option>
                            <option value="Programlama Dilleri">Programlama Dilleri</option>
                            <option value="Araçlar & DevOps">Araçlar & DevOps (Git, Docker vb.)</option>
                        </select>
                    </div>
                    <span asp-validation-for="Category" class="ap-hidden-validation"></span>
                </div>
            </div>
        </div>

        <div class="ap-form-group">
            <label class="ap-form-label">
                <i class="fa-solid fa-chart-line"></i> Seviye (1-100)
            </label>
            <input class="ap-input" asp-for="Level" type="number" min="1" max="100" />
            <span asp-validation-for="Level" class="ap-hidden-validation"></span>
        </div>

        <button type="submit" class="ap-btn-edit-submit">
            <i class="fa-solid fa-arrows-rotate"></i> Değişiklikleri Güncelle
        </button>

    </form>
</div>