@model SkillDto

<style>
    /* Ortak Form CSS */
    .ap-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        animation: ap-fade-up 0.4s var(--ease) both;
    }

    .ap-page-title {
        color: var(--text);
        font-weight: 700;
        font-size: 1.5rem;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .ap-btn-back {
        background: var(--surface);
        color: var(--text-dim);
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid var(--line);
        transition: all 0.2s var(--ease);
    }

        .ap-btn-back:hover {
            background: var(--surface-hover);
            color: var(--text);
            transform: translateX(-4px);
        }

    .ap-form-card {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 32px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
        animation: ap-fade-up 0.5s var(--ease) 0.1s both;
    }

    .ap-form-group {
        margin-bottom: 24px;
    }

    .ap-form-label {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--text-dim);
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 10px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

        .ap-form-label i {
            color: var(--brand-light);
            font-size: 1rem;
        }

    .ap-input {
        width: 100%;
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 14px 16px;
        color: var(--text);
        font-size: 0.95rem;
        font-family: inherit;
        transition: all 0.3s var(--ease);
        color-scheme: dark;
    }

        .ap-input::placeholder {
            color: rgba(139, 147, 167, 0.4);
        }

        .ap-input:focus {
            outline: none;
            border-color: var(--brand);
            background: rgba(0, 0, 0, 0.35);
            box-shadow: 0 0 0 4px rgba(109, 94, 249, 0.15);
        }

    /* Edit Sayfasına Özel Buton Rengi */
    .ap-btn-edit-submit {
        background: linear-gradient(135deg, #f59e0b, #fbbf24);
        color: #171c28;
        border: none;
        border-radius: 12px;
        padding: 14px 28px;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: transform 0.2s var(--ease), box-shadow 0.2s var(--ease);
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-top: 10px;
    }

        .ap-btn-edit-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px -6px rgba(245, 158, 11, 0.6);
        }

    
</style>

<div class="ap-page-header">
    <h2 class="ap-page-title">Yetenek Düzenle</h2>
    <a class="ap-btn-back" href="/Admin/Skill/Index">
        <i class="fa-solid fa-arrow-left"></i> Geri Dön
    </a>
</div>

<div class="ap-form-card">
    <form method="post">

        <input type="hidden" asp-for="Id" />

        <div class="row">
            <div class="col-md-6">
                <div class="ap-form-group">
                    <label class="ap-form-label"><i class="fa-solid fa-bolt"></i> Yetenek Adı</label>
                    <input class="ap-input" asp-for="Name" required />
                </div>
            </div>

            <div class="col-md-6">
                <div class="ap-form-group">
                    <label class="ap-form-label"><i class="fa-solid fa-layer-group"></i> Kategori</label>
                    <input class="ap-input" asp-for="Category" required />
                </div>
            </div>
        </div>

        <div class="ap-form-group">
            <label class="ap-form-label"><i class="fa-solid fa-chart-line"></i> Seviye (1-100)</label>
            <input class="ap-input" asp-for="Level" type="number" min="1" max="100" required />
        </div>

        <button type="submit" class="ap-btn-edit-submit">
            <i class="fa-solid fa-arrows-rotate"></i> Değişiklikleri Güncelle
        </button>

    </form>
</div>