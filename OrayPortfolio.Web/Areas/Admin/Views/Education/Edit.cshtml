@using OrayPortfolio.Application.DTOs.Education
@model EducationDto

<style>
    /* Input altı hataları tamamen gizle */
    .ap-hidden-validation {
        display: none !important;
    }

    /* Premium kırmızı hata kutusu */
    .ap-error-box {
        background: rgba(255, 0, 0, 0.12);
        border: 1px solid rgba(255, 0, 0, 0.45);
        color: #ff3b3b;
        padding: 14px 18px;
        border-radius: 12px;
        margin-bottom: 20px;
        font-size: 14px;
        line-height: 1.45;
        animation: ap-fade-in 0.25s ease, ap-shake 0.45s ease;
    }

        .ap-error-box ul {
            margin: 0;
            padding-left: 20px;
        }

        .ap-error-box li {
            margin-bottom: 4px;
        }

    /* Ortak Form CSS */
    .ap-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        animation: ap-fade-up 0.4s var(--ease) both;
    }

    .ap-page-title {
        color: var(--text);
        font-weight: 700;
        font-size: 1.5rem;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .ap-btn-back {
        background: var(--surface);
        color: var(--text-dim);
        padding: 8px 16px;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid var(--line);
        transition: all 0.2s var(--ease);
    }

        .ap-btn-back:hover {
            background: var(--surface-hover);
            color: var(--text);
            transform: translateX(-4px);
        }

    .ap-form-card {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 32px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
        animation: ap-fade-up 0.5s var(--ease) 0.1s both;
    }

    .ap-form-group {
        margin-bottom: 24px;
    }

    .ap-form-label {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--text-dim);
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 10px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

        .ap-form-label i {
            color: var(--brand-light);
            font-size: 1rem;
        }

    .ap-input {
        width: 100%;
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 14px 16px;
        color: var(--text);
        font-size: 0.95rem;
        font-family: inherit;
        transition: all 0.3s var(--ease);
        color-scheme: dark;
    }

        .ap-input::placeholder {
            color: rgba(139, 147, 167, 0.4);
        }

        .ap-input:focus {
            outline: none;
            border-color: var(--brand);
            background: rgba(0, 0, 0, 0.35);
            box-shadow: 0 0 0 4px rgba(109, 94, 249, 0.15);
        }

    textarea.ap-input {
        min-height: 120px;
        resize: vertical;
    }

    .ap-btn-edit-submit {
        background: linear-gradient(135deg, #f59e0b, #fbbf24);
        color: #171c28;
        border: none;
        border-radius: 12px;
        padding: 14px 28px;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: transform 0.2s var(--ease), box-shadow 0.2s var(--ease);
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-top: 10px;
    }

        .ap-btn-edit-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px -6px rgba(245, 158, 11, 0.6);
        }
</style>

<div class="ap-page-header">
    <h2 class="ap-page-title">Eğitimi Düzenle</h2>
    <a asp-action="Index" class="ap-btn-back">
        <i class="fa-solid fa-arrow-left"></i> Geri Dön
    </a>
</div>

<div class="ap-form-card">

    <!-- 🔥 TÜM VALIDASYON HATALARINI KIRMIZI KUTUDA GÖSTER -->
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="ap-error-box">
            <ul>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@error.ErrorMessage</li>
                }
            </ul>
        </div>
    }

    <!-- 📌 FOTOĞRAF YÜKLEYEBİLMEK İÇİN ENCTYPE EKLENDİ -->
    <form asp-area="Admin" asp-controller="Education" asp-action="Edit" method="post" enctype="multipart/form-data">

        <!-- 📌 GÜVENLİK: CSRF (Sahte İstek) Kilidi Eklendi -->
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="LogoImageUrl" />

        <div class="row">
            <div class="col-md-8">
                <div class="ap-form-group">
                    <label class="ap-form-label"><i class="fa-solid fa-building-columns"></i> Okul / Üniversite</label>
                    <input asp-for="School" class="ap-input" />
                    <span asp-validation-for="School" class="ap-hidden-validation"></span>
                </div>
            </div>

            <!-- 📌 LOGO YÜKLEME ALANI -->
            <div class="col-md-4">
                <div class="ap-form-group">
                    <label class="ap-form-label"><i class="fa-solid fa-image"></i> Kurum Logosu (İsteğe Bağlı)</label>
                    @if (!string.IsNullOrEmpty(Model.LogoImageUrl))
                    {
                        <div class="mb-2 d-flex align-items-center gap-3">
                            <img src="@Model.LogoImageUrl" alt="Mevcut Logo" style="width: 45px; height: 45px; border-radius: 50%; object-fit: cover; border: 1px solid var(--line);" />
                            <!-- 📌 text-muted yerine var(--text-dim) kullanıldı -->
                            <span style="color: var(--text-dim); font-size: 0.85rem; font-weight: 500;">Mevcut Logo</span>
                        </div>
                    }
                    <input type="file" name="LogoImage" class="ap-input" accept="image/*" style="padding: 10px;" />
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="ap-form-group">
                    <label class="ap-form-label"><i class="fa-solid fa-graduation-cap"></i> Derece</label>
                    <input asp-for="Degree" class="ap-input" />
                    <span asp-validation-for="Degree" class="ap-hidden-validation"></span>
                </div>
            </div>

            <div class="col-md-6">
                <div class="ap-form-group">
                    <label class="ap-form-label"><i class="fa-solid fa-book-open"></i> Bölüm</label>
                    <input asp-for="Department" class="ap-input" />
                    <span asp-validation-for="Department" class="ap-hidden-validation"></span>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="ap-form-group">
                    <label class="ap-form-label"><i class="fa-regular fa-calendar"></i> Başlangıç Tarihi</label>
                    <input asp-for="StartDate" type="date" class="ap-input" />
                    <span asp-validation-for="StartDate" class="ap-hidden-validation"></span>
                </div>
            </div>

            <div class="col-md-6">
                <div class="ap-form-group">
                    <label class="ap-form-label"><i class="fa-regular fa-calendar-check"></i> Bitiş Tarihi</label>
                    <input asp-for="EndDate" type="date" class="ap-input" />
                    <span asp-validation-for="EndDate" class="ap-hidden-validation"></span>
                </div>
            </div>
        </div>

        <div class="ap-form-group">
            <label class="ap-form-label"><i class="fa-solid fa-align-left"></i> Açıklama</label>
            <textarea asp-for="Description" class="ap-input"></textarea>
            <span asp-validation-for="Description" class="ap-hidden-validation"></span>
        </div>

        <button type="submit" class="ap-btn-edit-submit">
            <i class="fa-solid fa-arrows-rotate"></i> Güncelle
        </button>

    </form>
</div>