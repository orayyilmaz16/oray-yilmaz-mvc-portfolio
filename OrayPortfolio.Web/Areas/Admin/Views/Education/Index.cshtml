@using OrayPortfolio.Application.DTOs.Education
@model List<EducationDto>

<style>
    /* Ortak Liste CSS */
    .ap-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        animation: ap-fade-up 0.4s var(--ease) both;
    }

    .ap-page-title {
        color: var(--text);
        font-weight: 700;
        font-size: 1.5rem;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .ap-btn-primary {
        background: linear-gradient(135deg, var(--brand), var(--brand-light));
        color: #fff;
        padding: 10px 20px;
        border-radius: 12px;
        font-size: 14.5px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: none;
        transition: transform 0.2s var(--ease), box-shadow 0.2s var(--ease);
    }

        .ap-btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px -6px rgba(109, 94, 249, 0.6);
            color: #fff;
        }

    .ap-table-wrapper {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 16px;
        overflow: hidden;
        animation: ap-fade-up 0.5s var(--ease) 0.1s both;
        box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    }

    .ap-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
        margin: 0;
    }

        .ap-table th {
            background: rgba(0, 0, 0, 0.2);
            color: var(--text-dim);
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 16px 20px;
            border-bottom: 1px solid var(--line);
            font-weight: 600;
        }

        .ap-table td {
            padding: 16px 20px;
            border-bottom: 1px solid var(--line);
            color: var(--text);
            vertical-align: middle;
            font-size: 0.95rem;
            transition: background 0.2s var(--ease);
        }

        .ap-table tbody tr:hover td {
            background: var(--surface-hover);
        }

        .ap-table tbody tr:last-child td {
            border-bottom: none;
        }

    .ap-table-title {
        font-weight: 600;
        color: var(--text);
    }

    .ap-action-btns {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
    }

    .ap-btn-icon {
        width: 36px;
        height: 36px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s var(--ease);
        border: 1px solid transparent;
        font-size: 14px;
    }

    .ap-btn-edit {
        background: rgba(255, 193, 7, 0.1);
        color: #ffc107;
    }

        .ap-btn-edit:hover {
            background: rgba(255, 193, 7, 0.2);
            border-color: rgba(255, 193, 7, 0.4);
            transform: translateY(-2px);
            color: #ffc107;
        }

    .ap-btn-delete {
        background: rgba(251, 69, 112, 0.1);
        color: var(--danger);
    }

        .ap-btn-delete:hover {
            background: rgba(251, 69, 112, 0.2);
            border-color: rgba(251, 69, 112, 0.4);
            transform: translateY(-2px);
            color: var(--danger);
        }

    .ap-date-text {
        color: var(--text-dim);
        font-size: 0.9rem;
        font-family: 'JetBrains Mono', monospace;
    }

    .ap-degree-badge {
        background: rgba(45, 212, 191, 0.15);
        color: var(--accent);
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 600;
        display: inline-block;
        border: 1px solid rgba(45, 212, 191, 0.2);
    }

    .ap-empty-state {
        padding: 60px 20px;
        text-align: center;
    }

        .ap-empty-state i {
            font-size: 3rem;
            color: var(--line);
            margin-bottom: 16px;
        }

        .ap-empty-state p {
            color: var(--text-dim);
            font-size: 1rem;
            margin: 0;
        }

    
</style>

<div class="ap-page-header">
    <h2 class="ap-page-title">Eğitimler</h2>
    <a asp-action="Create" class="ap-btn-primary">
        <i class="fa-solid fa-plus"></i> Yeni Eğitim Ekle
    </a>
</div>

<div class="ap-table-wrapper">
    <table class="ap-table">
        <thead>
            <tr>
                <th>Okul</th>
                <th>Bölüm</th>
                <th>Derece</th>
                <th>Başlangıç</th>
                <th>Bitiş</th>
                <th style="text-align: right;">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td class="ap-table-title">
                            <i class="fa-solid fa-building-columns me-2" style="color: var(--text-faint);"></i> @item.School
                        </td>
                        <td>@item.Department</td>
                        <td>
                            <span class="ap-degree-badge">@item.Degree</span>
                        </td>
                        <td class="ap-date-text">@item.StartDate.ToString("dd.MM.yyyy")</td>
                        <td class="ap-date-text">@item.EndDate.ToString("dd.MM.yyyy")</td>
                        <td>
                            <div class="ap-action-btns">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="ap-btn-icon ap-btn-edit" title="Düzenle">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="ap-btn-icon ap-btn-delete" title="Sil"
                                   onclick="return confirm('Bu eğitim kaydını silmek istediğinize emin misiniz?');">
                                    <i class="fa-solid fa-trash-can"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6">
                        <div class="ap-empty-state">
                            <i class="fa-solid fa-user-graduate"></i>
                            <p>Henüz eklenmiş bir eğitim bilgisi bulunmuyor.</p>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>