@{
    ViewData["Title"] = "Medya Yükle";
}

<style>
    /* Ortak Form CSS */
    .ap-page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
        animation: ap-fade-up 0.4s var(--ease) both;
    }

    .ap-page-title {
        color: var(--text);
        font-weight: 700;
        font-size: 1.5rem;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .ap-form-card {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 32px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
        animation: ap-fade-up 0.5s var(--ease) 0.1s both;
    }

    .ap-form-group {
        margin-bottom: 24px;
    }

    .ap-form-label {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--text-dim);
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 10px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

        .ap-form-label i {
            color: var(--brand-light);
            font-size: 1rem;
        }

    .ap-input {
        width: 100%;
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 14px 16px;
        color: var(--text);
        font-size: 0.95rem;
        font-family: inherit;
        transition: all 0.3s var(--ease);
    }

        .ap-input::placeholder {
            color: rgba(139, 147, 167, 0.4);
        }

        .ap-input:focus {
            outline: none;
            border-color: var(--brand);
            background: rgba(0, 0, 0, 0.35);
            box-shadow: 0 0 0 4px rgba(109, 94, 249, 0.15);
        }

        /* Dosya Yükleme (File Input) Özelleştirmesi */
        .ap-input[type="file"] {
            padding: 10px;
        }

            .ap-input[type="file"]::file-selector-button {
                background: var(--surface-hover);
                color: var(--text);
                border: 1px solid var(--line);
                border-radius: 8px;
                padding: 8px 16px;
                margin-right: 16px;
                font-family: inherit;
                font-weight: 600;
                cursor: pointer;
                transition: all 0.2s var(--ease);
            }

                .ap-input[type="file"]::file-selector-button:hover {
                    background: rgba(109, 94, 249, 0.15);
                    border-color: var(--brand-light);
                    color: var(--brand-light);
                }

    .ap-btn-submit {
        background: linear-gradient(135deg, var(--brand), var(--brand-light));
        color: #fff;
        border: none;
        border-radius: 12px;
        padding: 14px 28px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.2s var(--ease), box-shadow 0.2s var(--ease);
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-top: 10px;
    }

        .ap-btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px -6px rgba(109, 94, 249, 0.6);
        }

   
</style>

<div class="ap-page-header">
    <h2 class="ap-page-title">Medya Yükle</h2>
</div>

<div class="ap-form-card">
    <form asp-area="Admin" asp-controller="Media" asp-action="Upload" method="post" enctype="multipart/form-data">

        <div class="ap-form-group">
            <label class="ap-form-label"><i class="fa-solid fa-cloud-arrow-up"></i> Dosya Seç</label>
            <input type="file" name="file" class="ap-input" required />
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="ap-form-group">
                    <label class="ap-form-label"><i class="fa-solid fa-folder-open"></i> Klasör</label>
                    <input type="text" name="folder" class="ap-input" value="projects" placeholder="Örn: projects, certificates..." required />
                </div>
            </div>

            <div class="col-md-6">
                <div class="ap-form-group">
                    <label class="ap-form-label"><i class="fa-solid fa-hashtag"></i> Project Id (Opsiyonel)</label>
                    <input type="number" name="projectId" class="ap-input" placeholder="İlişkilendirilecek projenin ID'si" />
                </div>
            </div>
        </div>

        <button type="submit" class="ap-btn-submit">
            <i class="fa-solid fa-upload"></i> Dosyayı Yükle
        </button>

    </form>
</div>