@{
    ViewData["Title"] = "Medya Yükle";
}

<h2>Medya Yükle</h2>

<form asp-area="Admin" asp-controller="Media" asp-action="Upload" method="post" enctype="multipart/form-data">
    <div class="form-group">
        <label>Dosya Seç</label>
        <input type="file" name="file" class="form-control" />
    </div>

    <div class="form-group">
        <label>Klasör</label>
        <input type="text" name="folder" class="form-control" value="projects" />
    </div>

    <div class="form-group">
        <label>Project Id</label>
        <input type="number" name="projectId" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary mt-3">Yükle</button>
</form>
