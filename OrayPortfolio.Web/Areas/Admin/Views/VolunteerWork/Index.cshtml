@model List<VolunteerWorkDto>

<h2>Gönüllü Çalışmalar</h2>

<a asp-action="Create" class="btn btn-primary mb-3">Yeni Ekle</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Organizasyon</th>
            <th>Rol</th>
            <th>Başlangıç</th>
            <th>Bitiş</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Organization</td>
                <td>@item.Role</td>
                <td>@item.StartDate.ToShortDateString()</td>
                <td>@item.EndDate?.ToShortDateString()</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Düzenle</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>

