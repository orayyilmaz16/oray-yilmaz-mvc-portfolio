@model VolunteerWorkUpdateDto

<h2>Gönüllü Çalışma Düzenle</h2>

<form method="post">

    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label>Organizasyon</label>
        <input class="form-control" asp-for="Organization" />
    </div>

    <div class="mb-3">
        <label>Rol</label>
        <input class="form-control" asp-for="Role" />
    </div>

    <div class="mb-3">
        <label>Açıklama</label>
        <textarea class="form-control" asp-for="Description"></textarea>
    </div>

    <div class="mb-3">
        <label>Başlangıç Tarihi</label>
        <input type="date" class="form-control" asp-for="StartDate" />
    </div>

    <div class="mb-3">
        <label>Bitiş Tarihi</label>
        <input type="date" class="form-control" asp-for="EndDate" />
    </div>

    <button class="btn btn-success">Güncelle</button>
</form>
