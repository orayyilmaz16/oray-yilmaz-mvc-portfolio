@using OrayPortfolio.Domain.Entities
@model IEnumerable<Certificate>

<h2 class="mb-4">Sertifikalar</h2>

<div class="row">

    @foreach (var c in Model)
    {
        <div class="col-md-4 mb-4" data-aos="fade-up">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body">

                    <!-- Başlık -->
                    <h5 class="card-title">@c.Title</h5>

                    <!-- Veren Kurum -->
                    <p class="text-muted">@c.Issuer</p>

                    <!-- Tarih -->
                    <small class="text-muted">
                        @c.Date?.ToString("dd MMM yyyy")
                    </small>

                    <div class="mt-3">

                        <!-- Sertifika URL (isteğe bağlı) -->
                        @if (!string.IsNullOrEmpty(c.CertificateUrl))
                        {
                            <a href="@c.CertificateUrl" target="_blank" class="btn btn-primary btn-sm me-2">
                                <i class="fa-solid fa-arrow-up-right-from-square"></i> Görüntüle
                            </a>
                        }

                    </div>

                    <!-- 📌 Yeni Medya Sistemi: Tek Dosya (PDF veya Görsel) -->
                    @if (!string.IsNullOrEmpty(c.FileUrl))
                    {
                        <hr />

                        <h6>Sertifika Dosyası</h6>

                        @if (c.FileUrl.EndsWith(".pdf"))
                        {
                            <!-- PDF ise buton -->
                            <a href="@c.FileUrl" target="_blank" class="btn btn-outline-primary w-100 mt-2">
                                <i class="fa-solid fa-file-pdf"></i> PDF Aç
                            </a>
                        }
                        else
                        {
                            <!-- Görsel ise thumbnail -->
                            <img src="@c.FileUrl" class="img-fluid rounded shadow-sm mt-2" />
                        }
                    }

                </div>

            </div>

        </div>
    }

</div>
