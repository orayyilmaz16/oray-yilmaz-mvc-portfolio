@using OrayPortfolio.Domain.Entities
@model IEnumerable<Certificate>

<h2 class="mb-4">Sertifikalar</h2>

<div class="row">

    @foreach (var c in Model)
    {
        <div class="col-md-4 mb-4" data-aos="fade-up">

            <div class="card shadow-sm border-0 h-100">

                <div class="card-body">

                    <!-- Başlık -->
                    <h5 class="card-title">@c.Title</h5>

                    <!-- Veren Kurum -->
                    <p class="text-muted">@c.Issuer</p>

                    <!-- Tarih -->
                    <small class="text-muted">
                        @c.Date.ToString("dd MMM yyyy")
                    </small>

                    <div class="mt-3">

                        <!-- Sertifika Linki -->
                        @if (!string.IsNullOrEmpty(c.CertificateUrl))
                        {
                            <a href="@c.CertificateUrl" target="_blank" class="btn btn-primary btn-sm me-2">
                                <i class="fa-solid fa-arrow-up-right-from-square"></i> Görüntüle
                            </a>
                        }

                    </div>

                    <!-- Medya Dosyaları -->
                    @if (c.MediaFiles != null && c.MediaFiles.Any())
                    {
                        <hr />

                        <h6>Ek Dosyalar</h6>

                        <div class="row mt-2">

                            @foreach (var media in c.MediaFiles)
                            {
                                <div class="col-md-6 mb-3">
                                    <div class="card shadow-sm border-0">

                                        @if (media.FileType == "image")
                                        {
                                            <img src="@media.FilePath" class="img-fluid rounded" />
                                        }
                                        else
                                        {
                                            <a href="@media.FilePath" target="_blank" class="btn btn-outline-primary w-100">
                                                Dosyayı Aç
                                            </a>
                                        }

                                    </div>
                                </div>
                            }

                        </div>
                    }

                </div>

            </div>

        </div>
    }

</div>
