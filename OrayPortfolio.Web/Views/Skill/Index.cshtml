@using OrayPortfolio.Application.DTOs.Skill
@model IEnumerable<SkillUpdateDto>

@{
    ViewData["Title"] = "Oray Yılmaz | Yeteneklerim";
}

<style>
    /* ----- YETENEKLER SAYFASI ÖZEL TASARIMI ----- */

    /* Alt metinleri sistemin dinamik temasına bağladık */
    .text-muted,
    .port-page-subtitle {
        color: var(--text-muted) !important;
    }

    /* Boşluklar */
    .port-spacer {
        height: 100px;
    }

    .port-spacer-sm {
        height: 50px;
    }

    /* Sayfa Üst Başlığı (Page Header) */
    .port-page-header {
        text-align: center;
        padding: 6rem 0 3rem;
        position: relative;
    }

    .port-page-title {
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 800;
        letter-spacing: -1.5px;
        margin-bottom: 1rem;
        text-wrap: balance;
        color: var(--text-main);
    }

        .port-page-title i {
            background: linear-gradient(135deg, var(--brand-primary), var(--brand-secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-right: 10px;
        }

    .port-page-subtitle {
        font-size: clamp(1.1rem, 2vw, 1.25rem);
        max-width: 700px;
        margin: 0 auto;
        line-height: 1.8;
        text-wrap: balance;
    }

    /* --- YENİ NESİL KUTULU YETENEK KARTLARI --- */
    .port-skill-category-title {
        color: var(--text-main);
        font-size: 1.35rem;
        font-weight: 800;
        margin-top: 3.5rem;
        margin-bottom: 1.2rem;
        margin-left: 10px;
        display: flex;
        align-items: center;
        gap: 12px;
        letter-spacing: -0.5px;
    }

        .port-skill-category-title i {
            font-size: 1.4rem;
        }

    /* Kategori Kartlarını Kaplayan Dış Kutu (Cam Efekti) */
    .port-skill-group-box {
        background: rgba(255, 255, 255, 0.015);
        border: 1px solid rgba(255, 255, 255, 0.04);
        border-radius: 24px;
        padding: 30px;
        margin-bottom: 2rem;
        position: relative;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
    }

        /* Kutunun sol tarafındaki renkli dinamik çizgi/parlama */
        .port-skill-group-box::before {
            content: '';
            position: absolute;
            top: 25px;
            bottom: 25px;
            left: -1px;
            width: 3px;
            border-radius: 0 4px 4px 0;
            background-color: var(--cat-color);
            box-shadow: 0 0 15px var(--cat-color);
            opacity: 0.8;
        }

    .port-skill-item {
        background: rgba(15, 18, 25, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.03);
        padding: 16px 20px;
        border-radius: 12px;
        transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    }

        .port-skill-item:hover {
            transform: translateY(-3px);
            border-color: rgba(109, 94, 249, 0.4);
            box-shadow: 0 5px 15px rgba(109, 94, 249, 0.1);
        }

    .port-skill-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
        font-weight: 600;
        font-size: 0.95rem;
        color: var(--text-main);
    }

    .port-progress-bg {
        height: 6px;
        background: rgba(0, 0, 0, 0.4);
        border-radius: 6px;
        overflow: hidden;
    }

    .port-progress-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--brand-primary), var(--brand-secondary));
        border-radius: 6px;
        width: 0;
        transition: width 1.5s cubic-bezier(0.22, 1, 0.36, 1);
    }

   

    /* Açık Tema Desteği */
    [data-theme="light"] .port-skill-group-box {
        background: #ffffff;
        border: 1px solid rgba(0,0,0,0.08);
        box-shadow: 0 8px 20px rgba(0,0,0,0.04);
    }

    [data-theme="light"] .port-skill-item {
        background: #f8fafc;
        border: 1px solid rgba(0,0,0,0.05);
    }
</style>

<!-- SAYFA ÜST BAŞLIĞI (PAGE HEADER) -->
<section class="port-page-header container" data-aos="fade-down" data-aos-duration="800">
    <h1 class="port-page-title">
        <i class="fa-solid fa-bolt"></i> Uzmanlık Alanlarım
    </h1>
    <p class="port-page-subtitle">
        Proje geliştirirken ustalıkla kullandığım yazılım dilleri, framework'ler ve teknik yetkinliklerim.
    </p>
</section>

<!-- YETENEKLER LİSTESİ (KATEGORİ KUTULARINA BÖLÜNMÜŞ) -->
<section class="container" style="margin-bottom: 60px;">
    @{
        // 📌 Yetenekleri kategorilerine göre grupla (Bu sayfada limit yok, hepsi listelenir)
        var groupedSkills = Model?
            .GroupBy(s => string.IsNullOrWhiteSpace(s.Category) ? "Diğer Yetenekler" : s.Category)
            .OrderByDescending(g => g.Count())
            .ToList();
    }

    @if (groupedSkills != null && groupedSkills.Any())
    {
        foreach (var group in groupedSkills)
        {
            // 📌 DİNAMİK İKON VE RENK ATAMASI
            string iconClass = "fa-layer-group";
            string iconColor = "#94a3b8";

            if (group.Key.Contains("Web")) { iconClass = "fa-globe"; iconColor = "#60a5fa"; }
            else if (group.Key.Contains("Mobil")) { iconClass = "fa-mobile-screen"; iconColor = "#34d399"; }
            else if (group.Key.Contains("Veritabanı")) { iconClass = "fa-database"; iconColor = "#38bdf8"; }
            else if (group.Key.Contains("Yapay Zeka")) { iconClass = "fa-robot"; iconColor = "#a78bfa"; }
            else if (group.Key.Contains("Programlama")) { iconClass = "fa-code"; iconColor = "#f472b6"; }
            else if (group.Key.Contains("DevOps") || group.Key.Contains("Araçlar")) { iconClass = "fa-terminal"; iconColor = "#fb923c"; }

            <!-- KATEGORİ BAŞLIĞI (KUTU DIŞINDA) -->
            <h4 class="port-skill-category-title" data-aos="fade-right">
                <i class="fa-solid @iconClass" style="color: @iconColor;"></i> @group.Key
            </h4>

            <!-- 📌 KATEGORİ KUTUSU -->
            <div class="port-skill-group-box" style="--cat-color: @iconColor;" data-aos="fade-up">
                <div class="row g-3">
                    @{
                        int skillDelay = 100;
                    }

                    <!-- Bu kategorideki TÜM yetenekleri yüksekten düşüğe listele (Limit Yok) -->
                    @foreach (var skill in group.OrderByDescending(x => x.Level))
                    {
                        <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="@skillDelay">
                            <div class="port-skill-item">
                                <div class="port-skill-header">
                                    <span><i class="fa-solid fa-check me-2" style="color: #2dd4bf;"></i> @skill.Name</span>
                                    <span style="color: var(--brand-primary); font-weight: 800; font-family: 'JetBrains Mono', monospace;">%@skill.Level</span>
                                </div>
                                <div class="port-progress-bg">
                                    <div class="port-progress-fill" data-width="@skill.Level%"></div>
                                </div>
                            </div>
                        </div>
                        skillDelay += 50;
                    }
                </div>
            </div>
        }
    }
    else
    {
        <!-- EĞER HİÇ YETENEK YOKSA GÖSTERİLECEK ŞIK BOŞ DURUM EKRANI -->
        <div class="col-12 text-center py-5" data-aos="fade-in">
            <div class="p-5 rounded-4" style="background: rgba(23, 28, 40, 0.5); border: 1px dashed rgba(255, 255, 255, 0.2); max-width: 600px; margin: 0 auto; backdrop-filter: blur(10px);">
                <i class="fa-solid fa-screwdriver-wrench mb-3" style="font-size: 4rem; color: rgba(255, 255, 255, 0.7);"></i>
                <h3 style="color: var(--text-main); font-weight: 700; margin-bottom: 10px;">Henüz Yetenek Eklenmemiş</h3>
                <p class="m-0" style="color: var(--text-muted); font-size: 1.1rem; line-height: 1.6;">
                    Sahip olduğum teknik beceriler ve uzmanlık seviyelerim çok yakında burada olacak.
                </p>
            </div>
        </div>
    }
</section>

<div class="port-spacer"></div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            // --- İlerleme Çubukları (Progress Bar) İçin Intersection Observer ---
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const fill = entry.target;
                        const targetWidth = fill.getAttribute('data-width');
                        fill.style.width = targetWidth; // Genişliği animasyonla uygula
                        observer.unobserve(fill);
                    }
                });
            }, { threshold: 0.1 });

            // Sayfadaki tüm progress bar doldurma elemanlarını yakala
            const progressFills = document.querySelectorAll('.port-progress-fill');
            progressFills.forEach(fill => {
                observer.observe(fill);
            });
        });
    </script>
}