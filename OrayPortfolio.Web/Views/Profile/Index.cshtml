@using OrayPortfolio.Domain.Entities
@model Profile

<h2 class="mb-4">Hakkımda</h2>

<div class="card shadow-sm border-0 p-4" data-aos="fade-up">

    <div class="row">

        <!-- Sol Kısım: Fotoğraf + Temel Bilgiler -->
        <div class="col-md-4 text-center">

            @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
            {
                <img src="~/uploads/@Model.ProfileImageUrl"
                     class="rounded-circle shadow mb-3"
                     width="180"
                     alt="@Model.FullName" />
            }

            <h3 class="fw-bold">@Model.FullName</h3>
            <p class="text-muted">@Model.Title</p>

            <!-- Sosyal Medya -->
            <div class="mt-3">

                @if (!string.IsNullOrEmpty(Model.GithubUrl))
                {
                    <a href="@Model.GithubUrl" target="_blank" class="btn btn-dark btn-sm me-2">
                        <i class="fa-brands fa-github"></i>
                    </a>
                }

                @if (!string.IsNullOrEmpty(Model.LinkedinUrl))
                {
                    <a href="@Model.LinkedinUrl" target="_blank" class="btn btn-primary btn-sm me-2">
                        <i class="fa-brands fa-linkedin"></i>
                    </a>
                }

                @if (!string.IsNullOrEmpty(Model.InstagramUrl))
                {
                    <a href="@Model.InstagramUrl" target="_blank" class="btn btn-danger btn-sm">
                        <i class="fa-brands fa-instagram"></i>
                    </a>
                }

            </div>

            <!-- Email -->
            @if (!string.IsNullOrEmpty(Model.Email))
            {
                <div class="mt-3">
                    <a href="mailto:@Model.Email" class="btn btn-outline-secondary btn-sm">
                        <i class="fa-solid fa-envelope"></i> @Model.Email
                    </a>
                </div>
            }

        </div>

        <!-- Sağ Kısım: Biyografi -->
        <div class="col-md-8">

            <!-- Kısa Biyografi -->
            @if (!string.IsNullOrEmpty(Model.ShortBio))
            {
                <h5 class="fw-bold">Kısa Biyografi</h5>
                <p class="text-muted fs-5">@Model.ShortBio</p>
            }

            <hr />

            <!-- Uzun Biyografi -->
            @if (!string.IsNullOrEmpty(Model.LongBio))
            {
                <h5 class="fw-bold">Hakkımda Detaylı</h5>
                <p class="text-muted">@Model.LongBio</p>
            }

        </div>

    </div>

</div>
