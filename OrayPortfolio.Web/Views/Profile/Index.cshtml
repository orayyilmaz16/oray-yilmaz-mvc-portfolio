@using OrayPortfolio.Domain.Entities
@model Profile

@{
    ViewData["Title"] = $"{Model.FullName} | Hakkımda";
}

<style>
    /* ----- HAKKIMDA SAYFASI ÖZEL TASARIMI ----- */

    .port-spacer {
        height: 100px;
    }

    /* Sayfa Başlığı */
    .port-page-header {
        text-align: center;
        padding: 6rem 0 3rem;
        position: relative;
    }

    .port-page-title {
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 800;
        letter-spacing: -1.5px;
        margin-bottom: 1rem;
        color: var(--text-main);
    }

        .port-page-title i {
            background: linear-gradient(135deg, var(--brand-primary), var(--brand-secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-right: 10px;
        }

    /* Sol Taraf: Yapışkan Profil Kartı (Sticky Card) */
    .port-profile-sidebar {
        position: sticky;
        top: 120px; /* Header'ın altında duracağı mesafe */
    }

    .port-profile-card {
        background: rgba(23, 28, 40, 0.6);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 24px;
        padding: 40px 30px;
        text-align: center;
        box-shadow: 0 15px 35px rgba(0,0,0,0.2);
        transition: all var(--transition);
    }

    .port-avatar-wrapper {
        position: relative;
        display: inline-block;
        margin-bottom: 1.5rem;
    }

        .port-avatar-wrapper::after {
            content: '';
            position: absolute;
            inset: -4px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--brand-primary), var(--brand-secondary));
            z-index: -1;
            opacity: 0.7;
            animation: pulse-glow 3s infinite alternate;
        }

    .port-profile-img {
        width: 160px;
        height: 160px;
        object-fit: cover;
        border-radius: 50%;
        border: 4px solid var(--bg-base);
        transition: border-color var(--transition);
    }

    .port-profile-name {
        font-size: 1.8rem;
        font-weight: 800;
        color: var(--text-main);
        margin-bottom: 5px;
    }

    .port-profile-title {
        font-size: 1.1rem;
        color: var(--brand-secondary);
        font-weight: 500;
        margin-bottom: 25px;
    }

    /* Sosyal İkonlar */
    .port-social-bar {
        display: flex;
        gap: 12px;
        justify-content: center;
        margin-bottom: 25px;
        flex-wrap: wrap;
    }

    .port-social-link {
        width: 45px;
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        background: rgba(255, 255, 255, 0.03);
        color: var(--text-main);
        font-size: 1.2rem;
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: all 0.3s ease;
    }

        .port-social-link:hover {
            background: var(--brand-primary);
            color: #fff;
            transform: translateY(-5px);
            border-color: var(--brand-primary);
            box-shadow: 0 10px 20px rgba(109, 94, 249, 0.4);
        }

    /* İletişim Butonu */
    .port-btn-contact {
        background: rgba(109, 94, 249, 0.1);
        color: var(--brand-primary) !important;
        border: 1px solid rgba(109, 94, 249, 0.2);
        padding: 12px 24px;
        border-radius: 12px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        width: 100%;
        justify-content: center;
        transition: all 0.3s ease;
        text-decoration: none;
    }

        .port-btn-contact:hover {
            background: var(--brand-primary);
            color: #fff !important;
            box-shadow: 0 10px 20px rgba(109, 94, 249, 0.4);
            transform: translateY(-3px);
        }

    /* Sağ Taraf: Biyografi İçeriği */
    .port-bio-content {
        padding: 20px 0;
    }

    .port-short-bio-box {
        background: linear-gradient(145deg, rgba(23, 28, 40, 0.6), rgba(11, 14, 20, 0.4));
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-left: 4px solid var(--brand-secondary);
        border-radius: 16px;
        padding: 30px;
        margin-bottom: 40px;
        transition: all var(--transition);
    }

    .port-short-bio-text {
        font-size: 1.15rem;
        color: var(--text-main);
        line-height: 1.8;
        margin: 0;
        font-weight: 500;
    }

    .port-content-title {
        font-size: 1.8rem;
        font-weight: 800;
        color: var(--text-main);
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .port-long-bio-text {
        font-size: 1.05rem;
        color: var(--text-muted);
        line-height: 1.9;
    }

        .port-long-bio-text p {
            margin-bottom: 20px;
        }

    /* 📌 LİGHT MODE OVERRİDES (AÇIK TEMA EZMELERİ) */
    [data-theme="light"] .port-profile-card {
        background: rgba(255, 255, 255, 0.85);
        border-color: rgba(0, 0, 0, 0.08);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.05);
    }

    [data-theme="light"] .port-short-bio-box {
        /* Karanlık gradyan kalkıyor, yerine çok soft, transparan bir mavi/mor ton geliyor */
        background: rgba(79, 70, 229, 0.05);
        border-color: rgba(79, 70, 229, 0.15);
        border-left: 4px solid var(--brand-primary);
    }

    [data-theme="light"] .port-social-link {
        background: rgba(0, 0, 0, 0.03);
        border-color: rgba(0, 0, 0, 0.08);
        color: var(--text-main);
    }

        [data-theme="light"] .port-social-link:hover {
            background: var(--brand-primary);
            color: #fff;
            border-color: var(--brand-primary);
        }

    [data-theme="light"] .port-btn-contact {
        background: rgba(79, 70, 229, 0.08);
        color: var(--brand-primary) !important;
        border-color: rgba(79, 70, 229, 0.2);
    }

        [data-theme="light"] .port-btn-contact:hover {
            background: var(--brand-primary);
            color: #fff !important;
        }

    /* Mobil Uyumluluk */
    @@media (max-width: 991.98px) {
        .port-profile-sidebar {
            position: relative;
            top: 0;
            margin-bottom: 40px;
        }

        .port-page-header {
            padding: 4rem 0 2rem;
        }
    }
</style>

<!-- SAYFA BAŞLIĞI -->
<section class="port-page-header container" data-aos="fade-down" data-aos-duration="800">
    <h1 class="port-page-title">
        <i class="fa-solid fa-user-astronaut"></i> Hakkımda
    </h1>
</section>

<section class="container">
    <div class="row g-5">

        <!-- SOL KISIM: YAPIŞKAN PROFİL KARTI -->
        <div class="col-lg-4">
            <div class="port-profile-sidebar">
                <div class="port-profile-card" data-aos="fade-up" data-aos-delay="100">

                    @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
                    {
                        <div class="port-avatar-wrapper">
                            <img src="@Model.ProfileImageUrl" class="port-profile-img" alt="@Model.FullName" />
                        </div>
                    }

                    <h3 class="port-profile-name">@Model.FullName</h3>
                    <p class="port-profile-title">@Model.Title</p>

                    <!-- Sosyal Medya İkonları -->
                    <div class="port-social-bar">
                        @if (!string.IsNullOrEmpty(Model.GithubUrl))
                        {
                            <a href="@Model.GithubUrl" target="_blank" class="port-social-link" title="GitHub">
                                <i class="fa-brands fa-github"></i>
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(Model.LinkedinUrl))
                        {
                            <a href="@Model.LinkedinUrl" target="_blank" class="port-social-link" title="LinkedIn">
                                <i class="fa-brands fa-linkedin-in"></i>
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(Model.InstagramUrl))
                        {
                            <a href="@Model.InstagramUrl" target="_blank" class="port-social-link" title="Instagram">
                                <i class="fa-brands fa-instagram"></i>
                            </a>
                        }
                    </div>

                    <!-- Email / İletişim Butonu -->
                    @if (!string.IsNullOrEmpty(Model.Email))
                    {
                        <a href="mailto:@Model.Email" class="port-btn-contact">
                            <i class="fa-solid fa-paper-plane"></i> Benimle İletişime Geç
                        </a>
                    }

                </div>
            </div>
        </div>

        <!-- SAĞ KISIM: BİYOGRAFİ İÇERİĞİ -->
        <div class="col-lg-8">
            <div class="port-bio-content">

                <!-- Kısa Biyografi (Vurgulu Kutu) -->
                @if (!string.IsNullOrEmpty(Model.ShortBio))
                {
                    <div class="port-short-bio-box" data-aos="fade-left" data-aos-delay="200">
                        <p class="port-short-bio-text">
                            <i class="fa-solid fa-quote-left me-2" style="color: var(--brand-secondary); opacity: 0.5;"></i>
                            @Model.ShortBio
                        </p>
                    </div>
                }

                <!-- Uzun Biyografi -->
                @if (!string.IsNullOrEmpty(Model.LongBio))
                {
                    <div data-aos="fade-left" data-aos-delay="300">
                        <h4 class="port-content-title">
                            <i class="fa-solid fa-book-open text-primary" style="font-size: 1.4rem;"></i> Hikayem & Detaylar
                        </h4>

                        <div class="port-long-bio-text mt-4">
                            <!-- Metin içindeki \n karakterlerini <br/> etiketine çeviririz ki paragraflar bozulmasın -->
                            @Html.Raw(Model.LongBio.Replace("\n", "<br/><br/>"))
                        </div>
                    </div>
                }

            </div>
        </div>

    </div>
</section>
<div class="port-spacer"></div>