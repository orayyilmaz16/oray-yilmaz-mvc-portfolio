@using OrayPortfolio.Application.DTOs.Education
@model IEnumerable<EducationDto>

@{
    ViewData["Title"] = "Eğitim Hayatım";
}

<style>
    /* ----- EĞİTİM SAYFASI ÖZEL TASARIMI ----- */

    /* Animasyonlar */
   

    /* Boşluklar */
    .port-spacer {
        height: 100px;
    }

    .port-spacer-sm {
        height: 50px;
    }

    /* Sayfa Üst Başlığı (Page Header) */
    .port-page-header {
        text-align: center;
        padding: 6rem 0 3rem;
        position: relative;
    }

    .port-page-title {
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 800;
        letter-spacing: -1.5px;
        margin-bottom: 1rem;
        text-wrap: balance;
    }

        .port-page-title i {
            background: linear-gradient(135deg, var(--brand-secondary), var(--brand-primary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-right: 10px;
        }

    .port-page-subtitle {
        color: var(--text-muted);
        font-size: clamp(1.1rem, 2vw, 1.25rem);
        max-width: 700px;
        margin: 0 auto;
        line-height: 1.8;
        text-wrap: balance;
    }

    /* --- Gelişmiş Timeline (Zaman Çizelgesi) Tasarımı --- */
    .port-timeline {
        position: relative;
        padding-left: 40px;
        list-style: none;
        margin: 0;
    }

        /* Ana Dikey Çizgi (Eğitime Özel Secondary Renk) */
        .port-timeline::before {
            content: '';
            position: absolute;
            top: 0;
            bottom: 0;
            left: 8px; /* Çizgi tam ortaya gelsin */
            width: 4px;
            background: linear-gradient(to bottom, var(--brand-secondary), var(--border-color) 80%, transparent);
            border-radius: 4px;
        }

    /* Kartların Kendisi (Glassmorphism) */
    .port-timeline-item {
        position: relative;
        margin-bottom: 50px;
        background: rgba(23, 28, 40, 0.5);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        padding: clamp(25px, 4vw, 40px);
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

        .port-timeline-item:hover {
            border-color: rgba(45, 212, 191, 0.5);
            background: rgba(23, 28, 40, 0.8);
            transform: translateX(10px);
            box-shadow: 0 15px 40px rgba(45, 212, 191, 0.15);
        }

    /* Noktalar */
    .port-timeline-dot {
        position: absolute;
        left: -40px;
        top: 45px;
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: var(--bg-base);
        border: 4px solid var(--border-color);
        transition: all 0.3s ease;
    }

    .port-timeline-item:hover .port-timeline-dot {
        border-color: var(--brand-secondary);
    }

    /* Aktif (Devam Eden) Eğitim Animasyonu */
    .port-timeline-item.active .port-timeline-dot {
        border-color: var(--brand-secondary);
        background: var(--brand-secondary);
        animation: radar-pulse-secondary 2s infinite cubic-bezier(0.66, 0, 0, 1);
    }

    /* İçerik Tipografisi */
    .port-timeline-date {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.95rem;
        color: var(--brand-secondary);
        background: rgba(45, 212, 191, 0.1);
        padding: 8px 16px;
        border-radius: 12px;
        border: 1px solid rgba(45, 212, 191, 0.2);
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .port-timeline-title {
        font-size: clamp(1.3rem, 3vw, 1.7rem);
        font-weight: 800;
        color: var(--text-main);
        margin-top: 1.2rem;
        margin-bottom: 5px;
        letter-spacing: -0.5px;
    }

    .port-timeline-school {
        font-size: 1.1rem;
        color: var(--brand-primary); /* Şirket için kullandığımız primary rengi burada okullar için kullanıyoruz */
        font-weight: 600;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .port-timeline-desc {
        color: var(--text-muted);
        font-size: 1.05rem;
        line-height: 1.8;
        margin-bottom: 0;
    }

    /* Mobil Uyumluluk */
   
</style>

<!-- SAYFA ÜST BAŞLIĞI (PAGE HEADER) -->
<section class="port-page-header container" data-aos="fade-down" data-aos-duration="800">
    <h1 class="port-page-title">
        <i class="fa-solid fa-graduation-cap"></i> Eğitim Hayatım
    </h1>
    <p class="port-page-subtitle">
        Akademik yolculuğum, uzmanlık kazandığım disiplinler ve edindiğim temel yetkinlikler.
    </p>
</section>

<div class="port-spacer-sm"></div>

<!-- EĞİTİM ZAMAN ÇİZELGESİ (TIMELINE) -->
<section class="container">
    <div class="row">
        <div class="col-lg-10 mx-auto">

            @if (Model != null && Model.Any())
            {
                <ul class="port-timeline">
                    @{
                        int delay = 100;
                    }

                    @foreach (var edu in Model.OrderByDescending(x => x.StartDate))
                    {
                        bool isOngoing = edu.EndDate.Year == 1;

                        <!-- Eğer eğitim aktifse "active" sınıfı verilir, bu radar efekti tetikler -->
                        <li class="port-timeline-item @(isOngoing ? "active" : "")" data-aos="fade-left" data-aos-delay="@delay">

                            <!-- Nokta -->
                            <div class="port-timeline-dot"></div>

                            <!-- Tarih Etiketi -->
                            <div class="d-flex align-items-center flex-wrap gap-3">
                                <span class="port-timeline-date">
                                    <i class="fa-regular fa-calendar"></i>
                                    @edu.StartDate.ToString("yyyy") →
                                    @(isOngoing ? "Devam Ediyor" : edu.EndDate.ToString("yyyy"))
                                </span>

                                @if (isOngoing)
                                {
                                    <span class="badge" style="background: rgba(109,94,249,0.2); color: var(--brand-primary); padding: 8px 14px; border-radius: 12px; font-size: 0.85rem; border: 1px solid rgba(109,94,249,0.3);">
                                        <i class="fa-solid fa-book-open-reader me-1"></i> Eğitim Sürüyor
                                    </span>
                                }
                            </div>

                            <!-- Bölüm (Büyük Başlık) & Okul -->
                            <h4 class="port-timeline-title">@edu.Department</h4>
                            <p class="port-timeline-school">
                                <i class="fa-solid fa-building-columns"></i> @edu.School
                            </p>

                            <!-- Açıklama (Enter boşluklarını korumak için Html.Raw kullanıldı) -->
                            @if (!string.IsNullOrWhiteSpace(edu.Description))
                            {
                                <p class="port-timeline-desc">
                                    @Html.Raw(edu.Description.Replace("\n", "<br/>"))
                                </p>
                            }

                        </li>

                        delay += 100;
                    }
                </ul>
            }
            else
            {
                <!-- BOŞ DURUM (EMPTY STATE) -->
                <div class="text-center py-5" data-aos="fade-in">
                    <div class="p-5 rounded-4" style="background: rgba(23, 28, 40, 0.5); border: 1px dashed rgba(255, 255, 255, 0.2); max-width: 600px; margin: 0 auto; backdrop-filter: blur(10px);">
                        <i class="fa-solid fa-school-flag mb-3" style="font-size: 4rem; color: rgba(255, 255, 255, 0.7);"></i>
                        <h3 style="color: var(--text-main); font-weight: 700; margin-bottom: 10px;">Henüz Eğitim Eklenmemiş</h3>
                        <p class="m-0" style="color: var(--text-muted); font-size: 1.1rem; line-height: 1.6;">
                            Akademik geçmişime ve mezuniyetlerime ait bilgiler çok yakında burada olacak.
                        </p>
                    </div>
                </div>
            }

        </div>
    </div>
</section>

<div class="port-spacer"></div>