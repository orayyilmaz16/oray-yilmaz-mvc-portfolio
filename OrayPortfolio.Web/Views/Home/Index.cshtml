@{
    ViewData["Title"] = "Oray Yılmaz - Portfolio";
}

<!-- HERO SECTION -->
<section class="py-5 text-center" data-aos="fade-up">
    <div class="container">
        <img src="~/img/profile.jpg" class="rounded-circle shadow mb-3" width="150" alt="Oray" />

        <h1 class="display-5 fw-bold">Merhaba, Ben Oray Yılmaz 👋</h1>
        <p class="lead text-muted mt-3">
            Full-Stack Developer • Web & Mobil Geliştirme • AI-First Development
        </p>

        <div class="mt-4">
            <a asp-controller="Project" asp-action="Index" class="btn btn-primary btn-lg me-2">
                <i class="fa-solid fa-diagram-project"></i> Projelerimi İncele
            </a>
            <a asp-controller="Profile" asp-action="Index" class="btn btn-outline-dark btn-lg">
                <i class="fa-solid fa-user"></i> Hakkımda
            </a>
        </div>
    </div>
</section>

<hr class="my-5" />

<!-- HAKKIMDA ÖZET -->
<section class="container" data-aos="fade-up">
    <h2 class="fw-bold mb-3">Kısaca Ben</h2>
    <p class="text-muted fs-5">
        Modern teknolojilerle çalışan, AI-first yaklaşımını benimseyen bir yazılım geliştiricisiyim.
        Web, mobil ve yapay zeka destekli uygulamalar geliştiriyorum.
        Temiz kod, performans ve kullanıcı deneyimi benim için öncelik.
    </p>

    <a asp-controller="Profile" asp-action="Index" class="btn btn-dark mt-2">
        Daha Fazlası <i class="fa-solid fa-arrow-right"></i>
    </a>
</section>

<hr class="my-5" />

<!-- PROJE ÖNİZLEMELERİ -->
<section class="container" data-aos="fade-up">
    <h2 class="fw-bold mb-4">Öne Çıkan Projeler</h2>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title">Portfolio Projesi</h5>
                    <p class="text-muted">ASP.NET Core MVC + Clean Architecture</p>
                    <a asp-controller="Project" asp-action="Index" class="btn btn-primary btn-sm">İncele</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title">AI Destekli Kodlama Aracı</h5>
                    <p class="text-muted">LLM tabanlı geliştirme deneyimi</p>
                    <a asp-controller="Project" asp-action="Index" class="btn btn-primary btn-sm">İncele</a>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <h5 class="card-title">Mobil Uygulama</h5>
                    <p class="text-muted">Flutter + Firebase</p>
                    <a asp-controller="Project" asp-action="Index" class="btn btn-primary btn-sm">İncele</a>
                </div>
