<section class="container" style="margin-bottom: 80px;">

    <div class="port-section-header text-center mb-5" data-aos="fade-down">
        <h2 class="port-section-title justify-content-center"><i class="fa-solid fa-bolt text-warning"></i> Uzmanlık Alanlarım</h2>
        <p class="port-section-subtitle mx-auto text-muted" style="max-width: 600px; margin: 0 auto; margin-top: 0.5rem;">
            Sürekli geliştirdiğim, modern projelerimde ustalıkla kullandığım teknoloji ve araçlar.
        </p>
    </div>

    @{
        var groupedSkills = Model.Skills
            .GroupBy(s => string.IsNullOrWhiteSpace(s.Category) ? "Diğer Yetenekler" : s.Category)
            .OrderByDescending(g => g.Count())
            .ToList();

        bool hasMoreSkills = false;
    }

    @if (groupedSkills.Any())
    {
        foreach (var group in groupedSkills.Take(4))
        {
            // 📌 DİNAMİK İKON VE RENK ATAMASI
            string iconClass = "fa-layer-group";
            string iconColor = "#94a3b8";

            if (group.Key.Contains("Web")) { iconClass = "fa-globe"; iconColor = "#60a5fa"; }
            else if (group.Key.Contains("Mobil")) { iconClass = "fa-mobile-screen"; iconColor = "#34d399"; }
            else if (group.Key.Contains("Veritabanı")) { iconClass = "fa-database"; iconColor = "#38bdf8"; }
            else if (group.Key.Contains("Yapay Zeka")) { iconClass = "fa-robot"; iconColor = "#a78bfa"; }
            else if (group.Key.Contains("Programlama")) { iconClass = "fa-code"; iconColor = "#f472b6"; }
            else if (group.Key.Contains("DevOps") || group.Key.Contains("Araçlar")) { iconClass = "fa-terminal"; iconColor = "#fb923c"; }

            <h4 class="port-skill-category-title" data-aos="fade-right">
                <i class="fa-solid @iconClass" style="color: @iconColor;"></i> @group.Key
            </h4>

            <div class="port-skill-group-box" style="--cat-color: @iconColor;" data-aos="fade-up">
                <div class="row g-3">
                    @{
                        int skillDelay = 100;
                        var skillsToShow = group.OrderByDescending(x => x.Level).ToList();
                        if (skillsToShow.Count > 3) hasMoreSkills = true;
                    }

                    @foreach (var skill in skillsToShow.Take(3))
                    {
                        <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="@skillDelay">
                            <div class="port-skill-item">
                                <div class="port-skill-header">
                                    <span><i class="fa-solid fa-check me-2" style="color: #2dd4bf;"></i> @skill.Name</span>
                                    <span style="color: var(--brand-primary);">%@skill.Level</span>
                                </div>
                                <div class="port-progress-bg">
                                    <div class="port-progress-fill" data-width="@skill.Level%"></div>
                                </div>
                            </div>
                        </div>
                        skillDelay += 50;
                    }
                </div>
            </div>
        }

        if (groupedSkills.Count > 4) { hasMoreSkills = true; }

        @if (hasMoreSkills)
        {
            <div class="text-center mt-3" data-aos="fade-up">
                <a asp-controller="Skill" asp-action="Index" class="port-btn-outline" style="border-color: transparent;">
                    Tümünü Keşfet <i class="fa-solid fa-arrow-right ms-2"></i>
                </a>
            </div>
        }
    }
    else
    {
        <div class="text-center text-muted py-5" data-aos="fade-in">
            <i class="fa-solid fa-code mb-3" style="font-size: 3rem; opacity: 0.5;"></i>
            <p>Henüz bir yetenek eklenmemiş.</p>
        </div>
    }

</section>

<div class="port-spacer"></div>

