                        <i class="fa-solid fa-quote-right port-ref-quote-icon"></i>
                        <p class="port-ref-content">"@refer.Comment"</p>

                        <div class="mt-auto pt-3 d-flex align-items-center gap-3" style="border-top: 1px solid var(--border-color); transform: translateZ(20px);">

                            @if (!string.IsNullOrEmpty(refer.ProfileImageUrl))
                            {
                                <img src="@refer.ProfileImageUrl" class="port-ref-avatar" alt="@refer.FullName" style="width: 50px; height: 50px; border-radius: 50%; object-fit: cover; border: 2px solid rgba(255,255,255,0.05);" />
                            }
                            else
                            {
                                <div class="port-ref-avatar" style="width: 50px; height: 50px; border-radius: 50%; background: linear-gradient(135deg, var(--brand-primary), var(--brand-secondary)); display: flex; justify-content: center; align-items: center; color: white; font-weight: bold; font-size: 1.2rem;">
                                    @(string.IsNullOrWhiteSpace(refer.FullName) ? "R" : refer.FullName.Substring(0, 1).ToUpper())
                                </div>
                            }

                            <div class="flex-grow-1">
                                <h6 style="color: var(--text-main); font-weight: 700; margin-bottom: 2px;">@refer.FullName</h6>
                                <p class="text-muted" style="font-size: 0.85rem; margin: 0; margin-bottom: 12px;">@refer.Position, @refer.Company</p>

                                <div class="d-flex flex-wrap gap-2">
                                    @if (!string.IsNullOrEmpty(refer.LinkedinUrl))
                                    {
                                        <a href="@refer.LinkedinUrl" target="_blank" class="port-contact-badge" title="LinkedIn Profili">
                                            <i class="fa-brands fa-linkedin" style="color: #0a66c2;"></i> LinkedIn
                                        </a>
                                    }
                                    @if (!string.IsNullOrEmpty(refer.Email))
                                    {
                                        <a href="mailto:@refer.Email" class="port-contact-badge" title="E-posta Gönder">
                                            <i class="fa-solid fa-envelope" style="color: var(--brand-primary);"></i> @refer.Email
                                        </a>
                                    }
                                    @if (!string.IsNullOrEmpty(refer.Phone))
                                    {
                                        <a href="tel:@refer.Phone.Replace(" ", "")" class="port-contact-badge" title="Ara">
                                            <i class="fa-solid fa-phone" style="color: var(--brand-secondary);"></i> @refer.Phone
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                refDelay += 100;
            }
        </div>

        @if (Model.References.Count() > 3)
        {
            <div class="text-center mt-5" data-aos="fade-up">
                <a asp-controller="Reference" asp-action="Index" class="port-btn-outline" style="border-color: transparent;">
                    Tümünü Keşfet <i class="fa-solid fa-arrow-right ms-2"></i>
                </a>
            </div>
        }
    </section>
    <div class="port-spacer"></div>
}
<section class="container" data-aos="zoom-in" data-aos-duration="1000" style="margin-bottom: 40px;">

    <div class="text-center mb-4">
        <h2 style="font-size: clamp(2.5rem, 5vw, 3.5rem); font-weight: 800; color: var(--text-main); margin-bottom: 15px; letter-spacing: -1px;">
            Yeni bir proje mi var?
        </h2>
        <p class="text-muted" style="font-size: clamp(1.05rem, 2vw, 1.25rem); max-width: 680px; margin: 0 auto; line-height: 1.8;">
            Fikirlerinizi dijital dünyada hayata geçirmek, modern ve ölçeklenebilir mimariler kurmak için buradayım. Hemen bir mesaj bırakın.
        </p>
    </div>

    <div class="port-contact-wrapper">

        <form id="contactForm">
            @Html.AntiForgeryToken()
            <div style="display: none; opacity: 0; position: absolute; top: -9999px; left: -9999px;" aria-hidden="true">
                <input asp-for="ContactForm.WebsiteUrl" tabindex="-1" autocomplete="off" />
            </div>

            <div class="row g-4">

                <div class="col-md-6" data-aos="fade-up" data-aos-delay="100">
                    <div class="port-input-group">
                        <input asp-for="ContactForm.FullName" class="port-contact-input" placeholder="Adınız Soyadınız" autocomplete="off" />
                        <i class="fa-solid fa-user port-input-icon"></i>
                    </div>
                    <span asp-validation-for="ContactForm.FullName"></span>
                </div>

                <div class="col-md-6" data-aos="fade-up" data-aos-delay="200">
                    <div class="port-input-group">
                        <input asp-for="ContactForm.Email" class="port-contact-input" placeholder="E-posta Adresiniz" autocomplete="off" />
                        <i class="fa-solid fa-envelope port-input-icon"></i>
                    </div>
                    <span asp-validation-for="ContactForm.Email"></span>
                </div>

                <div class="col-12" data-aos="fade-up" data-aos-delay="300">
                    <div class="port-input-group">
                        <input asp-for="ContactForm.Subject" class="port-contact-input" placeholder="Konu (Örn: Web Projesi, Danışmanlık)" autocomplete="off" />
                        <i class="fa-solid fa-tag port-input-icon"></i>
                    </div>
                    <span asp-validation-for="ContactForm.Subject"></span>
                </div>

                <div class="col-12" data-aos="fade-up" data-aos-delay="400">
                    <div class="port-input-group">
                        <textarea asp-for="ContactForm.Message" class="port-contact-input" rows="5" placeholder="Projenizden veya fikrinizden detaylıca bahsedin..."></textarea>
                        <i class="fa-solid fa-comment-dots port-input-icon"></i>
                    </div>
                    <span asp-validation-for="ContactForm.Message"></span>
                </div>

                <div class="col-12 text-center mt-4" data-aos="zoom-in" data-aos-delay="500">
                    <button type="submit" id="submitBtn" class="port-btn-submit w-100" style="padding: 18px 45px; max-width: 320px;">
                        Mesajı Gönder <i class="fa-solid fa-paper-plane"></i>
                    </button>
                </div>

            </div>
        </form>

    </div>
</section>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/vanilla-tilt/1.8.1/vanilla-tilt.min.js" integrity="sha512-wC/cunGGDjXSl9OHUH0RuqSyW4YNLlsPwhcLxwWW1CR4OeC2E1xpcdZz2DeQkEmums41laI+eGMw95IJ15SS3g==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <script src="https://unpkg.com/typed.js@2.1.0/dist/typed.umd.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

        // --- 1. TYPED.JS (Yazı Yazma Animasyonu) ---
        var title = "@Model.Profile.Title";
        var typed = new Typed('#typed-text', {
        strings: [title, "AI Researcher", "Technical Consultant"],
        typeSpeed: 60,
        backSpeed: 40,
        backDelay: 2000,
        loop: true,
        cursorChar: '|'
        });

        // --- 2. PROGRESS BAR ANİMASYONU (Scroll edilince dolar) ---
        const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
        if (entry.isIntersecting) {
        const fill = entry.target;
        const targetWidth = fill.getAttribute('data-width');
        fill.style.width = targetWidth;
        observer.unobserve(fill);
        }
        });
        }, { threshold: 0.1 });

        const progressFills = document.querySelectorAll('.port-progress-fill');
        progressFills.forEach(fill => {
        observer.observe(fill);
        });
        });
    </script>
}