<section class="container">
    <div class="port-section-header" data-aos="fade-right">
        <h2 class="port-section-title"><i class="fa-solid fa-compass"></i> Profesyonel Yolculuğum</h2>
        <p class="port-section-subtitle">Kariyerimde iz bırakan değerli deneyimlerim.</p>
    </div>

    <div class="row">
        <div class="col-lg-10 mx-auto">
            <ul class="port-timeline">
                @{
                    int expDelay = 100;
                }
                @foreach (var exp in Model.LatestExperiences.Take(3))
                {
                    // 📌 Tarih Geçmişse Şu Anki Yazmaması İçin Dinamik Mantık
                    bool isCurrentExp = !exp.EndDate.HasValue || exp.EndDate.Value.Year <= 1 || exp.EndDate.Value >= DateTime.Now;

                    <li class="port-timeline-item @(isCurrentExp ? "active" : "")" data-aos="fade-left" data-aos-delay="@expDelay">
                        <div class="port-timeline-dot"></div>
                        <div class="d-flex align-items-start gap-3 gap-md-4">

                            <div class="flex-shrink-0 pt-1">
                                <img src="@(!string.IsNullOrEmpty(exp.LogoImageUrl) ? exp.LogoImageUrl : Model.Profile.ProfileImageUrl)" class="port-company-logo" alt="@exp.Company Logo" loading="lazy" />
                            </div>

                            <div class="flex-grow-1">
                                <div class="d-flex align-items-center mb-3 flex-wrap gap-2">
                                    <span class="badge" style="background: rgba(109, 94, 249, 0.1); color: var(--brand-primary); padding: 6px 12px; border: 1px solid rgba(109, 94, 249, 0.2);">
                                        <i class="fa-regular fa-calendar me-1"></i> @(exp.StartDate?.ToString("MMM yyyy") ?? "-") → @(!exp.EndDate.HasValue || exp.EndDate.Value.Year <= 1 ? "Devam Ediyor" : exp.EndDate.Value.ToString("MMM yyyy"))
                                    </span>
                                    @if (isCurrentExp)
                                    {
                                        <span class="badge" style="background: rgba(45,212,191,0.2); color: var(--brand-secondary); padding: 6px 12px;">Şu Anki</span>
                                    }
                                </div>
                                <h4 style="font-size: clamp(1.2rem, 3vw, 1.5rem); font-weight: 800; color: var(--text-main); margin-bottom: 5px;">@exp.Position</h4>
                                <p style="font-size: 1.05rem; font-weight: 500;" class="text-muted"><i class="fa-regular fa-building me-2 text-primary"></i>@exp.Company</p>
                                <p class="m-0 mt-3 text-muted" style="line-height: 1.7;">@exp.Description</p>
                            </div>
                        </div>
                    </li>
                    expDelay += 100;
                }
            </ul>

            @if (Model.LatestExperiences.Count() > 3)
            {
                <div class="text-center mt-4" data-aos="fade-up">
                    <a asp-controller="Experience" asp-action="Index" class="port-btn-outline" style="border-color: transparent;">
                        Tümünü Keşfet <i class="fa-solid fa-arrow-right ms-2"></i>
                    </a>
                </div>
            }
        </div>
    </div>
</section>

