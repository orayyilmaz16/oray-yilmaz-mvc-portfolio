@using OrayPortfolio.Web.Models
@model HomeViewModel

@{
    ViewData["Title"] = $"{Model.Profile.FullName} | Ana Sayfa";
}

<style>
    /* ----- SAYFA ÖZEL MİKRO-ANİMASYONLAR VE KUSURSUZ TASARIM ----- */

    /* 📌 KESİN ÇÖZÜM: Tüm alt metinleri sistemin dinamik temasına bağladık */
    .text-muted,
    .port-card-text,
    .port-timeline-desc,
    .port-page-subtitle,
    .port-hero-subtitle {
        color: var(--text-muted) !important;
    }

    /* Boşluklar */
    .port-spacer {
        height: 120px;
    }

    /* Bölüm Başlıkları */
    .port-section-header {
        margin-bottom: 4rem;
        position: relative;
    }

    .port-section-title {
        font-size: clamp(2rem, 4vw, 2.5rem);
        font-weight: 800;
        display: flex;
        align-items: center;
        gap: 16px;
        color: var(--text-main);
        margin-bottom: 0.8rem;
        letter-spacing: -0.5px;
        text-wrap: balance;
    }

        .port-section-title i {
            background: linear-gradient(135deg, var(--brand-primary), var(--brand-secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-size: clamp(1.8rem, 3vw, 2.2rem);
        }

    .port-section-subtitle {
        font-size: clamp(1rem, 2vw, 1.15rem);
        margin-left: calc(clamp(1.8rem, 3vw, 2.2rem) + 16px);
        max-width: 600px;
        line-height: 1.7;
        text-wrap: balance;
    }

    /* --- Hero (Karşılama) Alanı --- */
    .port-hero {
        min-height: 95vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        position: relative;
        padding-top: 6rem;
    }

    .port-status-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        background: rgba(45, 212, 191, 0.08);
        border: 1px solid rgba(45, 212, 191, 0.2);
        color: var(--brand-secondary);
        padding: 8px 18px;
        border-radius: 50px;
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 2.5rem;
        backdrop-filter: blur(8px);
    }

    .port-status-dot {
        width: 8px;
        height: 8px;
        background-color: var(--brand-secondary);
        border-radius: 50%;
        animation: radar-pulse 2s infinite cubic-bezier(0.66, 0, 0, 1);
    }

    .port-avatar-wrapper {
        position: relative;
        display: inline-block;
        margin-bottom: 2.5rem;
        animation: float 6s ease-in-out infinite;
    }

        .port-avatar-wrapper::after {
            content: '';
            position: absolute;
            inset: -6px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--brand-primary), var(--brand-secondary));
            z-index: -1;
            animation: pulse-glow 3s infinite alternate;
        }

    .port-hero-img {
        width: clamp(160px, 20vw, 210px);
        height: clamp(160px, 20vw, 210px);
        object-fit: cover;
        border-radius: 50%;
        border: 6px solid var(--bg-base);
        filter: contrast(1.05) brightness(1.05);
    }

    .port-hero-title {
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        font-weight: 800;
        letter-spacing: -2px;
        margin-bottom: 1rem;
        line-height: 1.1;
        text-wrap: balance;
        color: var(--text-main);
    }

        .port-hero-title span {
            background: linear-gradient(135deg, var(--brand-primary), var(--brand-secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .port-hero-subtitle {
        font-size: clamp(1.1rem, 2.5vw, 1.4rem);
        max-width: 750px;
        margin: 0 auto 2.5rem;
        line-height: 1.8;
        min-height: 40px;
    }

    .typed-cursor {
        color: var(--brand-secondary);
        font-size: 1.5rem;
    }

    /* Sosyal İkonlar */
    .port-social-bar {
        display: flex;
        gap: 16px;
        justify-content: center;
        margin-bottom: 3.5rem;
        flex-wrap: wrap;
    }

    .port-social-link {
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.02);
        color: var(--text-main);
        font-size: 1.3rem;
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: all var(--transition);
        backdrop-filter: blur(5px);
    }

        .port-social-link:hover {
            background: var(--brand-primary);
            color: #fff;
            transform: translateY(-6px) rotate(8deg);
            border-color: var(--brand-primary);
            box-shadow: 0 12px 24px rgba(109, 94, 249, 0.4);
        }

    /* Scroll İndikatörü */
    .port-scroll-indicator {
        position: absolute;
        bottom: 40px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 1.8rem;
        animation: scroll-bounce 2.5s infinite;
        transition: opacity 0.3s;
    }

        .port-scroll-indicator:hover {
            color: var(--brand-secondary) !important;
        }

    /* Butonlar */
    .port-btn-primary, .port-btn-outline {
        padding: 16px 36px;
        border-radius: 14px;
        font-weight: 700;
        font-size: 1.05rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition: all 0.3s ease;
        text-decoration: none;
        cursor: pointer;
    }

    .port-btn-primary {
        background: linear-gradient(135deg, var(--brand-primary), #8b7bff);
        color: #fff !important;
        border: none;
    }

        .port-btn-primary:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 30px -5px rgba(109, 94, 249, 0.5);
        }

    .port-btn-outline {
        background: rgba(255,255,255,0.02);
        color: var(--text-main) !important;
        border: 1px solid rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
    }

        .port-btn-outline:hover {
            background: var(--surface-hover);
            border-color: var(--brand-primary);
            transform: translateY(-4px);
            box-shadow: 0 15px 30px -5px rgba(0, 0, 0, 0.3);
        }

    /* --- Hakkımda Kutu --- */
    .port-about-box {
        background: linear-gradient(145deg, rgba(23, 28, 40, 0.8), rgba(11, 14, 20, 0.95));
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 24px;
        padding: clamp(30px, 5vw, 60px);
        position: relative;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.3);
        backdrop-filter: blur(20px);
    }

        .port-about-box::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 6px;
            height: 100%;
            background: linear-gradient(to bottom, var(--brand-primary), var(--brand-secondary));
        }

    .port-about-icon {
        position: absolute;
        right: -20px;
        bottom: -20px;
        font-size: 18rem;
        color: rgba(255,255,255,0.015);
        z-index: 0;
        pointer-events: none;
        transform: rotate(-10deg);
    }

    /* --- Proje Kartları --- */
    .port-card {
        background: rgba(23, 28, 40, 0.6);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 24px;
        overflow: hidden;
        height: 100%;
        display: flex;
        flex-direction: column;
        transform-style: preserve-3d;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        transition: border-color 0.3s ease;
    }

        .port-card:hover {
            border-color: rgba(109, 94, 249, 0.4);
        }

    .port-card-img-wrapper {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9;
        overflow: hidden;
        transform: translateZ(20px);
    }

    .port-card-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s ease;
    }

    .port-card:hover .port-card-img {
        transform: scale(1.08) rotate(1deg);
    }

    .port-card-img-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(23, 28, 40, 0.95) 0%, transparent 70%);
        z-index: 1;
    }

    .port-card-body {
        padding: 30px;
        display: flex;
        flex-direction: column;
        flex: 1;
        position: relative;
        z-index: 2;
        transform: translateZ(30px);
    }

    .port-card-title {
        font-size: 1.3rem;
        font-weight: 800;
        color: var(--text-main);
        margin-bottom: 12px;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        word-break: break-word;
        text-shadow: 0 2px 10px rgba(0,0,0,0.8);
    }

    [data-theme="light"] .port-card-title {
        text-shadow: none !important;
    }

    /* --- Zaman Çizelgesi --- */
    .port-timeline {
        position: relative;
        padding-left: 40px;
        list-style: none;
        margin: 0;
    }

        .port-timeline::before {
            content: '';
            position: absolute;
            top: 0;
            bottom: 0;
            left: 8px;
            width: 4px;
            background: linear-gradient(to bottom, var(--brand-primary), var(--border-color) 80%, transparent);
            border-radius: 4px;
        }

        .port-timeline.education-timeline::before {
            background: linear-gradient(to bottom, var(--brand-secondary), var(--border-color) 80%, transparent);
        }

    .port-timeline-item {
        position: relative;
        margin-bottom: 40px;
        background: rgba(23, 28, 40, 0.5);
        backdrop-filter: blur(10px);
        padding: clamp(20px, 4vw, 35px);
        border-radius: 24px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: all 0.3s ease;
    }

        .port-timeline-item:hover {
            border-color: rgba(45, 212, 191, 0.4);
            background: rgba(23, 28, 40, 0.8);
            transform: translateX(8px);
        }

    .port-timeline-dot {
        position: absolute;
        left: -40px;
        top: 40px;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background: var(--bg-base);
        border: 4px solid var(--border-color);
        transition: all 0.3s ease;
    }

    .port-timeline-item.active .port-timeline-dot {
        border-color: var(--brand-secondary);
        background: var(--brand-secondary);
        box-shadow: 0 0 0 6px rgba(45, 212, 191, 0.2);
    }

    .port-timeline.education-timeline .port-timeline-dot {
        border-color: var(--brand-secondary);
    }

    /* 📌 DİNAMİK YUVARLAK LOGO/PROFİL FOTOĞRAFI */
    .port-company-logo {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        object-fit: cover;
        background-color: var(--surface);
        padding: 4px;
        border: 2px solid var(--border-color);
        box-shadow: 0 8px 16px rgba(0,0,0,0.1);
        transition: transform 0.4s ease, border-color 0.4s ease;
    }

    .port-timeline-item:hover .port-company-logo, .port-card:hover .port-company-logo {
        transform: scale(1.08) rotate(5deg);
        border-color: var(--brand-secondary);
    }

    [data-theme="light"] .port-company-logo {
        background-color: #fff;
        border-color: rgba(0,0,0,0.1);
    }

    /* --- YENİ NESİL KUTULU YETENEK KARTLARI --- */
    .port-skill-category-title {
        color: var(--text-main);
        font-size: 1.25rem;
        font-weight: 700;
        margin-top: 2rem;
        margin-bottom: 0.8rem;
        margin-left: 10px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .port-skill-category-title i {
            font-size: 1.3rem;
        }

    /* Kategori Kartlarını Kaplayan Dış Kutu */
    .port-skill-group-box {
        background: rgba(255, 255, 255, 0.015);
        border: 1px solid rgba(255, 255, 255, 0.04);
        border-radius: 24px;
        padding: 30px;
        margin-bottom: 3.5rem;
        position: relative;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

        /* Kutunun sol tarafındaki renkli dinamik çizgi/parlama */
        .port-skill-group-box::before {
            content: '';
            position: absolute;
            top: 25px;
            bottom: 25px;
            left: -1px;
            width: 3px;
            border-radius: 0 4px 4px 0;
            background-color: var(--cat-color);
            box-shadow: 0 0 15px var(--cat-color);
            opacity: 0.8;
        }

    .port-skill-item {
        background: rgba(15, 18, 25, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.03);
        padding: 18px 20px;
        border-radius: 14px;
        transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    }

        .port-skill-item:hover {
            transform: translateY(-3px);
            border-color: rgba(109, 94, 249, 0.4);
            box-shadow: 0 5px 15px rgba(109, 94, 249, 0.1);
        }

    .port-skill-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
        font-weight: 600;
        font-size: 0.95rem;
        color: var(--text-main);
    }

    .port-progress-bg {
        height: 6px;
        background: rgba(0, 0, 0, 0.4);
        border-radius: 6px;
        overflow: hidden;
    }

    .port-progress-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--brand-primary), var(--brand-secondary));
        border-radius: 6px;
        width: 0;
        transition: width 1.5s cubic-bezier(0.22, 1, 0.36, 1);
    }

    /* --- Referans Kartları --- */
    .port-ref-card {
        background: rgba(23, 28, 40, 0.6);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 24px;
        padding: 35px;
        position: relative;
        transition: all 0.3s ease;
        height: 100%;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        transform-style: preserve-3d;
    }

        .port-ref-card:hover {
            border-color: var(--brand-primary);
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(109, 94, 249, 0.1);
        }

    .port-ref-quote-icon {
        position: absolute;
        top: -10px;
        right: 20px;
        font-size: 6rem;
        color: rgba(255,255,255,0.02);
        z-index: 0;
        transform: translateZ(10px);
    }

    .port-ref-content {
        position: relative;
        z-index: 1;
        flex: 1;
        font-size: 1.05rem;
        font-style: italic;
        color: var(--text-main);
        margin-bottom: 20px;
        line-height: 1.7;
    }

    .port-ref-author {
        display: flex;
        align-items: center;
        gap: 15px;
        border-top: 1px solid var(--border-color);
        padding-top: 20px;
    }

    .port-ref-avatar {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--brand-primary), var(--brand-secondary));
        display: flex;
        justify-content: center;
        align-items: center;
        color: #fff;
        font-weight: 700;
        font-size: 1.2rem;
    }

    /* --- CTA (Call to Action) --- */
    .port-cta {
        background: linear-gradient(135deg, rgba(109, 94, 249, 0.1), rgba(45, 212, 191, 0.05));
        border: 1px solid rgba(109, 94, 249, 0.2);
        border-radius: 30px;
        padding: clamp(40px, 8vw, 80px) 20px;
        text-align: center;
        position: relative;
        overflow: hidden;
        backdrop-filter: blur(10px);
    }

        .port-cta::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.02) 0%, transparent 50%);
            animation: scroll-bounce 15s linear infinite;
            pointer-events: none; /* 📌 ÇÖZÜM 1: Mouse engellemesini kaldırır */
        }

    /* Mobil Uyumluluk */
    @@media (max-width: 768px) {
        .port-section-header {
            margin-bottom: 2.5rem;
        }

        .port-section-title {
            font-size: 2rem;
            justify-content: center;
            text-align: center;
        }

        .port-section-subtitle {
            margin-left: 0;
            text-align: center;
            font-size: 1rem;
        }

        .port-hero-title {
            text-align: center;
        }

        .port-timeline {
            padding-left: 20px;
        }

            .port-timeline::before {
                left: 0px;
            }

        .port-timeline-dot {
            left: -7px;
            width: 14px;
            height: 14px;
            top: 35px;
        }
    }

    /* --- YENİ NESİL İLETİŞİM FORMU (UI/UX) --- */
    .port-contact-wrapper {
        background: linear-gradient(145deg, rgba(23, 28, 40, 0.7), rgba(11, 14, 20, 0.9));
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 32px;
        padding: clamp(30px, 6vw, 60px);
        position: relative;
        overflow: hidden;
        box-shadow: 0 30px 60px rgba(0, 0, 0, 0.4);
        backdrop-filter: blur(20px);
        margin-top: 20px;
    }

    /* 📌 LİGHT MODE OVERRİDES (Açık Tema Form Ayarları) */
    [data-theme="light"] .port-contact-wrapper {
        background: linear-gradient(145deg, #ffffff, #f8fafc);
        border-color: rgba(0, 0, 0, 0.06);
        box-shadow: 0 30px 60px rgba(0, 0, 0, 0.06);
    }

    /* Dekoratif Arka Plan Işık Hüzmeleri (Animasyonlu) */
    .port-contact-wrapper::before {
        content: '';
        position: absolute;
        top: -50px;
        right: -50px;
        width: 250px;
        height: 250px;
        background: radial-gradient(circle, var(--brand-primary) 0%, transparent 70%);
        opacity: 0.15;
        border-radius: 50%;
        animation: float 6s ease-in-out infinite;
        pointer-events: none;
    }

    .port-contact-wrapper::after {
        content: '';
        position: absolute;
        bottom: -50px;
        left: -50px;
        width: 200px;
        height: 200px;
        background: radial-gradient(circle, var(--brand-secondary) 0%, transparent 70%);
        opacity: 0.15;
        border-radius: 50%;
        animation: float 8s ease-in-out infinite reverse;
        pointer-events: none;
    }

    /* Input Grubu ve İkonlar */
    .port-input-group {
        position: relative;
        margin-bottom: 0.5rem;
    }

    .port-input-icon {
        position: absolute;
        left: 20px;
        top: 20px;
        color: var(--text-muted);
        font-size: 1.1rem;
        transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
        pointer-events: none;
        opacity: 0.6;
        z-index: 2;
    }

    textarea ~ .port-input-icon {
        top: 22px; /* Textarea için ikonu biraz aşağı hizala */
    }

    /* Input Alanı (Kusursuz Cam Hissi) */
    .port-contact-input {
        background: rgba(255, 255, 255, 0.02);
        border: 2px solid rgba(255, 255, 255, 0.04);
        color: var(--text-main);
        border-radius: 18px;
        padding: 18px 20px 18px 55px; /* Soldan ikon için boşluk */
        font-size: 1.05rem;
        width: 100%;
        position: relative;
        z-index: 1;
        transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
    }

    [data-theme="light"] .port-contact-input {
        background: rgba(0, 0, 0, 0.02);
        border-color: rgba(0, 0, 0, 0.06);
    }

    .port-contact-input::placeholder {
        color: var(--text-muted);
        opacity: 0.7;
    }

    /* Focus (Odaklanma) Animasyonları */
    .port-contact-input:focus {
        background: rgba(0, 0, 0, 0.2);
        border-color: var(--brand-primary);
        box-shadow: 0 10px 25px rgba(109, 94, 249, 0.15);
        outline: none;
        transform: translateY(-3px); /* Odaklanınca input hafif havaya kalkar */
    }

    [data-theme="light"] .port-contact-input:focus {
        background: #ffffff;
        box-shadow: 0 10px 25px rgba(109, 94, 249, 0.15);
    }

    /* Input'a odaklanınca İkonun Parlaması */
    .port-input-group:focus-within .port-input-icon {
        color: var(--brand-primary);
        opacity: 1;
        transform: scale(1.15);
    }

    /* Gönder Butonu Animasyonları */
    .port-btn-submit {
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, var(--brand-primary), var(--brand-secondary));
        color: #fff !important;
        border: none;
        border-radius: 18px;
        font-weight: 700;
        font-size: 1.15rem;
        transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
        z-index: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        box-shadow: 0 8px 20px rgba(109, 94, 249, 0.3);
    }

        .port-btn-submit::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            transition: left 0.6s ease;
            z-index: -1;
        }

        .port-btn-submit:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(109, 94, 249, 0.5);
        }

            .port-btn-submit:hover::after {
                left: 100%; /* Üzerine gelince parlayan beyaz çizgi geçer */
            }

        .port-btn-submit i {
            transition: transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
        }

        .port-btn-submit:hover i {
            transform: translate(6px, -6px) scale(1.1); /* Kağıt uçak uçar efekti */
        }

    /* Özel Uyarı/Mesaj Tasarımları */
    .port-alert {
        border-radius: 16px;
        padding: 16px 20px;
        margin-bottom: 25px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 12px;
        text-align: left;
    }

    .port-alert-success {
        background: rgba(45, 212, 191, 0.15);
        border: 1px solid rgba(45, 212, 191, 0.3);
        color: var(--brand-secondary);
    }

    .port-alert-danger {
        background: rgba(251, 69, 112, 0.15);
        border: 1px solid rgba(251, 69, 112, 0.3);
        color: #fb4570;
    }

    .form-validation-error {
        font-size: 0.85rem;
        color: #fb4570;
        margin-top: 6px;
        display: inline-block;
        margin-left: 15px;
        font-weight: 600;
    }

    /* Hatalı Input'un Çerçevesi, Arka Planı ve Gölgesi */
    .input-validation-error {
        border-color: #fb4570 !important;
        background: rgba(251, 69, 112, 0.03) !important;
        box-shadow: 0 0 0 4px rgba(251, 69, 112, 0.15) !important;
    }

    [data-theme="light"] .input-validation-error {
        background: rgba(251, 69, 112, 0.05) !important;
    }

    /* Hatalı Input'un İkonu da Kırmızı Olsun */
    .input-validation-error ~ .port-input-icon {
        color: #fb4570 !important;
        opacity: 1 !important;
    }

    /* Alt Kısımdaki Kırmızı Uyarı Metni */
    .field-validation-error {
        color: #fb4570;
        font-size: 0.85rem;
        font-weight: 600;
        margin-top: 6px;
        display: block; /* Alta geçmesi için block yapıldı */
        margin-left: 15px;
        text-align: left;
        animation: form-shake 0.4s ease-in-out;
    }

    /* --- Referans İletişim Butonları (Hap Tasarım) --- */
    .port-contact-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.06);
        padding: 6px 14px;
        border-radius: 50px; /* Tam yuvarlak hap görünümü */
        color: var(--text-muted) !important;
        font-size: 0.85rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 0.3s ease;
    }

        .port-contact-badge:hover {
            background: rgba(109, 94, 249, 0.1);
            border-color: rgba(109, 94, 249, 0.3);
            color: var(--text-main) !important;
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }
</style>

