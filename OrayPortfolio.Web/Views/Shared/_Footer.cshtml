@using OrayPortfolio.Application.Interfaces.Services
@inject IProfileService ProfileService
@{
    // Admin panelinden girilen güncel profil bilgilerini asenkron olarak çekiyoruz
    var profile = await ProfileService.GetAsync();
}

<style>
    /* ----- FOOTER (ALT BİLGİ) TASARIMI ----- */

    .port-footer {
        background: linear-gradient(180deg, var(--bg-base) 0%, #080a0f 100%);
        border-top: 1px solid rgba(255, 255, 255, 0.03);
        padding: 6rem 0 2rem;
        margin-top: auto;
        position: relative;
        overflow: hidden;
    }

    /* 📌 LIGHT MODE OVERRIDES (AÇIK TEMA UYUMLULUĞU) */
    [data-theme="light"] .port-footer {
        background: linear-gradient(180deg, var(--bg-base) 0%, rgba(0, 0, 0, 0.03) 100%);
        border-top: 1px solid rgba(0, 0, 0, 0.06);
    }

    [data-theme="light"] .port-footer-social a {
        background: rgba(0, 0, 0, 0.04);
        border: 1px solid rgba(0, 0, 0, 0.08);
        color: var(--text-main);
    }

    [data-theme="light"] .port-footer-bottom {
        border-top: 1px solid rgba(0, 0, 0, 0.08);
    }

    /* Üst kısımdaki şık parlama efekti (Glow Line) */
    .port-footer::before {
        content: '';
        position: absolute;
        top: -1px;
        left: 50%;
        transform: translateX(-50%);
        width: 300px;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--brand-primary), var(--brand-secondary), transparent);
        box-shadow: 0 0 25px 3px var(--brand-primary);
        border-radius: 50%;
    }

    /* Marka / Logo Alanı */
    .port-footer-brand-logo {
        font-size: 1.6rem;
        font-weight: 800;
        color: var(--text-main) !important;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 1.2rem;
        transition: transform 0.3s ease;
        letter-spacing: -0.5px;
    }

        .port-footer-brand-logo:hover {
            transform: scale(1.02);
        }

        .port-footer-brand-logo i {
            background: linear-gradient(135deg, var(--brand-primary), var(--brand-secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-size: 1.8rem;
        }

    .port-footer-desc {
        color: var(--text-muted);
        font-size: 0.95rem;
        line-height: 1.8;
        padding-right: 20px;
        margin-bottom: 2rem;
    }

    /* Sosyal Medya İkonları */
    .port-footer-social {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
    }

        .port-footer-social a {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.05);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-main);
            font-size: 1.15rem;
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            text-decoration: none;
        }

            .port-footer-social a:hover {
                background: var(--brand-primary);
                color: #fff !important;
                transform: translateY(-5px);
                border-color: var(--brand-primary);
                box-shadow: 0 10px 20px rgba(109, 94, 249, 0.4);
            }

    /* Başlıklar */
    .port-footer-title {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--text-main);
        margin-bottom: 1.8rem;
        position: relative;
        padding-bottom: 12px;
        letter-spacing: 0.5px;
    }

        .port-footer-title::after {
            content: '';
            position: absolute;
            left: 0;
            bottom: 0;
            width: 40px;
            height: 3px;
            background: var(--brand-secondary);
            border-radius: 3px;
        }

    /* Hızlı Linkler */
    .port-footer-links {
        list-style: none;
        padding: 0;
        margin: 0;
    }

        .port-footer-links li {
            margin-bottom: 14px;
        }

        .port-footer-links a {
            color: var(--text-muted);
            text-decoration: none;
            font-size: 0.95rem;
            font-weight: 500;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 10px; /* 📌 İkon ve metin arası kusursuz boşluk */
        }

            .port-footer-links a i {
                font-size: 0.8rem;
                color: var(--brand-primary);
                transition: transform 0.3s ease, color 0.3s ease;
                opacity: 0.8;
            }

            .port-footer-links a:hover {
                color: var(--text-main);
                transform: translateX(6px);
            }

                .port-footer-links a:hover i {
                    color: var(--brand-secondary);
                    transform: scale(1.2);
                    opacity: 1;
                }

    /* İletişim Bilgileri */
    .port-footer-contact {
        list-style: none;
        padding: 0;
        margin: 0;
    }

        .port-footer-contact li {
            display: flex;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 22px;
        }

    .contact-icon {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: rgba(45, 212, 191, 0.1);
        color: var(--brand-secondary);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.15rem;
        flex-shrink: 0;
        border: 1px solid rgba(45, 212, 191, 0.2);
        transition: transform 0.3s ease, background 0.3s ease;
    }

    .port-footer-contact li:hover .contact-icon {
        background: rgba(45, 212, 191, 0.2);
        transform: scale(1.05) rotate(-5deg);
    }

    .contact-text span {
        display: block;
        font-size: 0.8rem;
        text-transform: uppercase;
        color: var(--text-muted);
        font-weight: 600;
        margin-bottom: 4px;
        letter-spacing: 0.5px;
    }

    .contact-text a, .contact-text p {
        color: var(--text-main);
        text-decoration: none;
        font-size: 1rem;
        font-weight: 500;
        margin: 0;
        transition: color 0.3s ease;
    }

        .contact-text a:hover {
            color: var(--brand-primary);
        }

    /* Alt Kısım (Copyright & Made With) */
    .port-footer-bottom {
        border-top: 1px solid rgba(255,255,255,0.05);
        padding-top: 2rem;
        margin-top: 4rem;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: center;
        gap: 15px;
    }

   

    .port-footer-text {
        color: var(--text-muted);
        font-size: 0.95rem;
        margin: 0;
    }

    .port-footer-brand-name {
        color: var(--brand-primary);
        font-weight: 700;
        text-decoration: none;
        transition: color 0.3s ease;
    }

        .port-footer-brand-name:hover {
            color: var(--brand-secondary);
        }

    
</style>

<footer class="port-footer">
    <div class="container relative" style="z-index: 1;">

        <div class="row g-5">
            <!-- 1. Sütun: Marka & Hakkında -->
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="100">
                <a href="/" class="port-footer-brand-logo">
                    <i class="fa-solid fa-code"></i> @(profile != null ? profile.FullName : "Oray Yılmaz")
                </a>
                <p class="port-footer-desc">
                    @(profile != null && !string.IsNullOrEmpty(profile.ShortBio)
                        ? (profile.ShortBio.Length > 120 ? profile.ShortBio.Substring(0, 120) + "..." : profile.ShortBio)
                        : "Modern, ölçeklenebilir ve kullanıcı odaklı dijital çözümler üreten geliştirici.")
                </p>

                <!-- Dinamik Sosyal Medya İkonları -->
                <div class="port-footer-social">
                    @if (profile != null)
                    {
                        @if (!string.IsNullOrEmpty(profile.GithubUrl))
                        {
                            <a href="@profile.GithubUrl" target="_blank" title="GitHub"><i class="fa-brands fa-github"></i></a>
                        }
                        @if (!string.IsNullOrEmpty(profile.LinkedinUrl))
                        {
                            <a href="@profile.LinkedinUrl" target="_blank" title="LinkedIn"><i class="fa-brands fa-linkedin-in"></i></a>
                        }
                        @if (!string.IsNullOrEmpty(profile.InstagramUrl))
                        {
                            <a href="@profile.InstagramUrl" target="_blank" title="Instagram"><i class="fa-brands fa-instagram"></i></a>
                        }
                        @if (!string.IsNullOrEmpty(profile.Email))
                        {
                            <a href="mailto:@profile.Email" title="Email Gönder"><i class="fa-solid fa-envelope"></i></a>
                        }
                    }
                </div>
            </div>

            <!-- 2. Sütun: Hızlı Menü -->
            <div class="col-lg-2 col-md-6" data-aos="fade-up" data-aos-delay="200">
                <h5 class="port-footer-title">Hızlı Menü</h5>
                <ul class="port-footer-links">
                    <li><a asp-controller="Project" asp-action="Index"><i class="fa-solid fa-angle-right"></i> Projeler</a></li>
                    <li><a asp-controller="Experience" asp-action="Index"><i class="fa-solid fa-angle-right"></i> Deneyimler</a></li>
                    <li><a asp-controller="Education" asp-action="Index"><i class="fa-solid fa-angle-right"></i> Eğitimler</a></li>
                    <li><a asp-controller="Profile" asp-action="Index"><i class="fa-solid fa-angle-right"></i> Hakkımda</a></li>
                </ul>
            </div>

            <!-- 3. Sütun: Ekstralar -->
            <div class="col-lg-2 col-md-6" data-aos="fade-up" data-aos-delay="300">
                <h5 class="port-footer-title">Ekstralar</h5>
                <ul class="port-footer-links">
                    <li><a asp-controller="Certificate" asp-action="Index"><i class="fa-solid fa-angle-right"></i> Sertifikalar</a></li>
                    <li><a asp-controller="Skill" asp-action="Index"><i class="fa-solid fa-angle-right"></i> Yetenekler</a></li>
                    <li><a asp-controller="Reference" asp-action="Index"><i class="fa-solid fa-angle-right"></i> Referanslar</a></li>
                    <li><a asp-controller="VolunteerWork" asp-action="Index"><i class="fa-solid fa-angle-right"></i> Gönüllü İşler</a></li>
                </ul>
            </div>

            <!-- 4. Sütun: İletişim Bilgileri -->
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="400">
                <h5 class="port-footer-title">İletişim</h5>
                <ul class="port-footer-contact">
                    <li>
                        <div class="contact-icon"><i class="fa-solid fa-envelope"></i></div>
                        <div class="contact-text">
                            <span>Email Gönderin</span>
                            @if (profile != null && !string.IsNullOrEmpty(profile.Email))
                            {
                                <a href="mailto:@profile.Email">@profile.Email</a>
                            }
                            else
                            {
                                <p class="m-0 text-muted">Belirtilmedi</p>
                            }
                        </div>
                    </li>
                    <li>
                        <div class="contact-icon"><i class="fa-solid fa-location-dot"></i></div>
                        <div class="contact-text">
                            <span>Konum</span>
                            <p class="m-0">Türkiye / Remote</p>
                        </div>
                    </li>
                </ul>
            </div>
        </div>

        <!-- 📌 YENİDEN DÜZENLENEN ALT KISIM -->
        <div class="port-footer-bottom">
            <p class="port-footer-text">
                © @DateTime.Now.Year <a href="/" class="port-footer-brand-name">@(profile != null ? profile.FullName : "OrayPortfolio")</a>. Tüm Hakları Saklıdır.
            </p>
            
        </div>

    </div>
</footer>