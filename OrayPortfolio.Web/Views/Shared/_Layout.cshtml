<!DOCTYPE html>
<html lang="tr" style="scroll-behavior: smooth;">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"]</title>

    <link rel="icon" type="image/png" href="~/img/favicon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
            /* ----- MODERN PORTFOLIO TEMA DEĞİŞKENLERİ (VARSAYILAN: DARK) ----- */
            :root {
                --bg-base: #0b0e14;
                --surface: #171c28;
                --surface-hover: #1f2533;
                --surface-glass: rgba(11, 14, 20, 0.75);
                --border-color: #242b3a;
                --text-main: #eef1f6;
                --text-muted: #8b93a7;
                --brand-primary: #6d5ef9;
                --brand-secondary: #2dd4bf;
                --transition: 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            }

            html {
                scroll-behavior: smooth;
            }

            /* ----- LIGHT MODE RENK DEĞİŞKENLERİ ----- */
            [data-theme="light"] {
                --bg-base: #f8fafc; /* Çok açık soft gri */
                --surface: #ffffff; /* Bembeyaz kartlar */
                --surface-hover: #f1f5f9;
                --surface-glass: rgba(255, 255, 255, 0.85);
                --border-color: #e2e8f0;
                --text-main: #0f172a; /* Koyu lacivert/siyah yazı */
                --text-muted: #64748b;
                --brand-primary: #4f46e5; /* Daha okunaklı bir mor */
                --brand-secondary: #0d9488; /* Daha koyu bir mint yeşili */
            }

                /* 📌 Açık Modda Görsel Düzenlemeler (Opacity ve Shadow Ezmeleri) */
                [data-theme="light"] .port-card,
                [data-theme="light"] .port-timeline-item,
                [data-theme="light"] .port-skill-item,
                [data-theme="light"] .port-ref-card,
                [data-theme="light"] .port-about-box,
                [data-theme="light"] .port-profile-card,
                [data-theme="light"] .port-detail-content-card,
                [data-theme="light"] .port-search-summary {
                    background: rgba(255, 255, 255, 0.85) !important;
                    border-color: rgba(0, 0, 0, 0.08) !important;
                    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03) !important;
                }

                /* Açık moddaki yazıları Dark moddan gelen zorunlu beyazlıktan kurtarır */
                [data-theme="light"] .text-muted,
                [data-theme="light"] .port-card-text,
                [data-theme="light"] .port-timeline-desc,
                [data-theme="light"] .port-page-subtitle,
                [data-theme="light"] .port-hero-subtitle {
                    color: var(--text-muted) !important;
                }

                /* Açık mod Buton ve Arka Plan ayarlamaları */
                [data-theme="light"] .port-progress-bg {
                    background: rgba(0, 0, 0, 0.05) !important;
                }

                [data-theme="light"] .port-btn-outline {
                    background: rgba(0, 0, 0, 0.02) !important;
                    border-color: rgba(0, 0, 0, 0.1) !important;
                    color: var(--text-main) !important;
                }

                    [data-theme="light"] .port-btn-outline:hover {
                        background: var(--brand-primary) !important;
                        border-color: var(--brand-primary) !important;
                        color: #ffffff !important;
                    }

                [data-theme="light"] .port-ref-quote-icon,
                [data-theme="light"] .port-about-icon {
                    color: rgba(0, 0, 0, 0.03) !important;
                }

                [data-theme="light"] .port-timeline-date,
                [data-theme="light"] .port-cert-date,
                [data-theme="light"] .port-tech-badge {
                    background: rgba(79, 70, 229, 0.08) !important; /* Açık mora çalan arkaplan */
                    border-color: rgba(79, 70, 229, 0.15) !important;
                    color: var(--brand-primary) !important;
                }

                [data-theme="light"] .port-company-logo,
                [data-theme="light"] .port-volunteer-logo {
                    border-color: rgba(0,0,0,0.1) !important;
                }


            /* ----- GENEL AYARLAR ----- */
            html, body {
                margin: 0 !important;
                padding: 0 !important;
                height: 100%;
            }

            body {
                background-color: var(--bg-base);
                color: var(--text-main);
                font-family: 'Plus Jakarta Sans', sans-serif;
                overflow-x: hidden;
                display: flex;
                flex-direction: column;
                min-height: 100vh;
                position: relative;
                transition: background-color 0.4s ease, color 0.4s ease; /* Temalar arası yumuşak geçiş */
            }

            ::selection {
                background: var(--brand-primary);
                color: #fff;
            }

            /* ----- CUSTOM SCROLLBAR ----- */
            ::-webkit-scrollbar {
                width: 8px;
            }

            ::-webkit-scrollbar-track {
                background: var(--bg-base);
            }

            ::-webkit-scrollbar-thumb {
                background: var(--border-color);
                border-radius: 10px;
            }

                ::-webkit-scrollbar-thumb:hover {
                    background: var(--brand-primary);
                }

            /* ----- ARKA PLAN PARLAMA EFEKTLERİ ----- */
            body::before {
                content: "";
                position: absolute;
                top: -10%;
                left: -10%;
                width: 50vw;
                height: 50vw;
                background: radial-gradient(circle, rgba(109, 94, 249, 0.08), transparent 70%);
                pointer-events: none;
                z-index: -1;
            }

            body::after {
                content: "";
                position: absolute;
                bottom: -20%;
                right: -10%;
                width: 40vw;
                height: 40vw;
                background: radial-gradient(circle, rgba(45, 212, 191, 0.04), transparent 70%);
                pointer-events: none;
                z-index: -1;
            }

            /* ----- İÇERİK ALANI ----- */
            .port-main-content {
                flex: 1 0 auto;
                padding-top: 100px;
                padding-bottom: 60px;
                position: relative;
                z-index: 1;
            }

            /* ----- PRELOADER ----- */
            #port-preloader {
                position: fixed;
                inset: 0;
                background: var(--bg-base);
                z-index: 9999;
                display: flex;
                justify-content: center;
                align-items: center;
                transition: opacity 0.5s var(--transition), visibility 0.5s;
            }

            .port-spinner {
                width: 50px;
                height: 50px;
                border: 3px solid rgba(109, 94, 249, 0.2);
                border-top-color: var(--brand-primary);
                border-radius: 50%;
                animation: port-spin 1s linear infinite;
            }
            

            /* ----- YUKARI ÇIK BUTONU ----- */
            .port-back-to-top {
                position: fixed;
                bottom: 30px;
                right: 30px;
                width: 45px;
                height: 45px;
                background: var(--surface-glass);
                backdrop-filter: blur(10px);
                border: 1px solid var(--border-color);
                color: var(--text-main);
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.2rem;
                cursor: pointer;
                opacity: 0;
                visibility: hidden;
                transform: translateY(20px);
                transition: all var(--transition);
                z-index: 1000;
            }

                .port-back-to-top.show {
                    opacity: 1;
                    visibility: visible;
                    transform: translateY(0);
                }

                .port-back-to-top:hover {
                    background: var(--brand-primary);
                    border-color: var(--brand-primary);
                    color: #fff;
                    transform: translateY(-5px);
                    box-shadow: 0 10px 20px rgba(109, 94, 249, 0.4);
                }

            /* ----- FOOTER ----- */
            .port-footer {
                background: linear-gradient(180deg, var(--bg-base) 0%, rgba(0,0,0,0.2) 100%);
                border-top: 1px solid rgba(255, 255, 255, 0.03);
                padding: 5rem 0 1.5rem;
                margin-top: auto;
                flex-shrink: 0;
                position: relative;
                overflow: hidden;
            }
    </style>

    <script>
            const savedTheme = localStorage.getItem('theme');
            const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            // Eğer kayıtlı tema yoksa koyu temayı varsayalım
            const currentTheme = savedTheme || (systemPrefersDark ? 'dark' : 'dark');
            document.documentElement.setAttribute('data-theme', currentTheme);
    </script>
</head>
<body>

    <div id="port-preloader">
        <div class="port-spinner"></div>
    </div>

    @await Html.PartialAsync("_Navbar")

    <main role="main" class="port-main-content">
        <div class="container" data-aos="fade-up" data-aos-duration="800">
            @RenderBody()
        </div>
    </main>

    <button class="port-back-to-top" id="backToTopBtn" title="Yukarı Çık">
        <i class="fa-solid fa-arrow-up"></i>
    </button>

    @await Html.PartialAsync("_Footer")

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
        // 1. AOS Animasyonlarını Başlat
        AOS.init({
        once: true,
        offset: 50,
        duration: 800,
        easing: 'ease-in-out-cubic',
        });

        // 2. Preloader'ı Kapat
        window.addEventListener('load', function() {
        const preloader = document.getElementById('port-preloader');
        if (preloader) {
        preloader.style.opacity = '0';
        setTimeout(() => { preloader.style.visibility = 'hidden'; }, 500);
        }
        });

        // 3. Yukarı Çık Butonu Mantığı
        const backToTopBtn = document.getElementById('backToTopBtn');
        if (backToTopBtn) {
        window.addEventListener('scroll', function () {
        if (window.scrollY > 300) { backToTopBtn.classList.add('show'); }
        else { backToTopBtn.classList.remove('show'); }
        });

        backToTopBtn.addEventListener('click', function () {
        window.scrollTo({ top: 0, behavior: 'smooth' });
        });
        }
        });
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
        const themeToggleBtn = document.getElementById('theme-toggle');
        const themeToggleIcon = document.getElementById('theme-toggle-icon');

        // Eğer navbar içine Butonu henüz eklemediysen bu kontrol hatayı önler
        if(themeToggleBtn && themeToggleIcon) {

        // Head içindeki script'in belirlediği temayı oku
        const currentTheme = document.documentElement.getAttribute('data-theme');
        updateToggleIcon(currentTheme);

        // Tıklama olayını dinle
        themeToggleBtn.addEventListener('click', () => {
        let theme = document.documentElement.getAttribute('data-theme');
        let newTheme = theme === 'dark' ? 'light' : 'dark';

        document.documentElement.setAttribute('data-theme', newTheme);
        localStorage.setItem('theme', newTheme);
        updateToggleIcon(newTheme);
        });

        // İkonu ve Buton Rengini Güncelleyen Fonksiyon
        function updateToggleIcon(theme) {
        if (theme === 'dark') {
        themeToggleIcon.className = 'fa-solid fa-sun'; // Koyu moddayken güneş (ışık) aç ikonu
        themeToggleBtn.style.color = 'var(--brand-secondary)'; // Mint yeşili ikon
        themeToggleBtn.style.borderColor = 'rgba(45, 212, 191, 0.3)';
        } else {
        themeToggleIcon.className = 'fa-solid fa-moon'; // Açık moddayken ay (karanlık) ikonu
        themeToggleBtn.style.color = 'var(--brand-primary)'; // Lacivert/Mor ikon
        themeToggleBtn.style.borderColor = 'rgba(79, 70, 229, 0.3)';
        }
        }
        }
        });
    </script>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
        if ($("#contactForm").length > 0) {
        $("#contactForm").on("submit", function (e) {
        e.preventDefault();
        e.stopImmediatePropagation();

        const form = $(this);

        if (!form.valid()) {
        return false;
        }

        Swal.fire({
        title: "Gönderiliyor...",
        text: "Lütfen bekleyin",
        allowOutsideClick: false,
        background: 'var(--bg-base)',
        color: 'var(--text-main)',
        didOpen: () => {
        Swal.showLoading();
        }
        });

        // 📌 KESİN ÇÖZÜM: Veri anahtarlarındaki "ContactForm." önekini siliyoruz
        const formData = new FormData(this);
        const data = {};

        formData.forEach((value, key) => {
        let cleanKey = key.includes(".") ? key.split(".")[1] : key;
        data[cleanKey] = value;
        });

        $.ajax({
        url: "/Home/SendMessage",
        type: "POST",
        contentType: "application/json",
        data: JSON.stringify(data),
        success: function (res) {
        if (res.success) {
        Swal.fire({
        icon: "success",
        title: "Mesaj Gönderildi!",
        text: res.message,
        confirmButtonColor: "#6d5ef9",
        background: 'var(--bg-base)',
        color: 'var(--text-main)',
        showClass: { popup: "animate__animated animate__fadeInDown" },
        hideClass: { popup: "animate__animated animate__fadeOutUp" }
        });

        form[0].reset();
        } else {
        Swal.fire({
        icon: "error",
        title: "Hata!",
        text: res.message,
        confirmButtonColor: "#fb4570",
        background: 'var(--bg-base)',
        color: 'var(--text-main)',
        showClass: { popup: "animate__animated animate__shakeX" }
        });
        }
        },
        error: function () {
        Swal.fire({
        icon: "error",
        title: "Sunucu Hatası",
        text: "Sistemde geçici bir arıza oluştu, lütfen daha sonra tekrar deneyin.",
        confirmButtonColor: "#fb4570",
        background: 'var(--bg-base)',
        color: 'var(--text-main)',
        showClass: { popup: "animate__animated animate__shakeX" }
        });
        }
        });
        });
        }
        });
    </script>

   

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>