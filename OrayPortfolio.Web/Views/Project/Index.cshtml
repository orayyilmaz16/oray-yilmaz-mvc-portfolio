@using OrayPortfolio.Domain.Entities
@model IEnumerable<Project>
@{
    ViewData["Title"] = "Oray Yılmaz | Projelerim";
}

<style>
    /* ----- PROJELER SAYFASI ÖZEL TASARIMI ----- */

    /* Boşluklar */
    .port-spacer {
        height: 100px;
    }

    .port-spacer-sm {
        height: 50px;
    }

    /* Sayfa Üst Başlığı (Page Header) */
    .port-page-header {
        text-align: center;
        padding: 6rem 0 3rem;
        position: relative;
    }

    .port-page-title {
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 800;
        letter-spacing: -1.5px;
        margin-bottom: 1rem;
        text-wrap: balance;
    }

        .port-page-title i {
            background: linear-gradient(135deg, var(--brand-primary), var(--brand-secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-right: 10px;
        }

    .port-page-subtitle {
        color: var(--text-muted);
        font-size: clamp(1.1rem, 2vw, 1.25rem);
        max-width: 700px;
        margin: 0 auto;
        line-height: 1.8;
        text-wrap: balance;
    }

    [data-theme="light"] .port-card-title {
        text-shadow: none !important;
    }

    /* --- Proje Kartları (3D Tilt, Cam Efekti ve Kusursuz Oranlar) --- */
    .port-card {
        background: rgba(23, 28, 40, 0.6);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 24px;
        overflow: hidden;
        height: 100%;
        display: flex;
        flex-direction: column;
        transform-style: preserve-3d; /* 3D Efekti aktif eder */
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        transition: border-color 0.4s ease, box-shadow 0.4s ease;
    }

        .port-card:hover {
            border-color: rgba(109, 94, 249, 0.4);
            box-shadow: 0 25px 50px -12px rgba(109, 94, 249, 0.25);
        }

    .port-card-img-wrapper {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9; /* Resimlerin asla sünmemesini sağlar */
        overflow: hidden;
        transform: translateZ(20px); /* Resmi hafif öne iter */
    }

    .port-card-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s cubic-bezier(0.25, 0.8, 0.25, 1);
    }

    .port-card:hover .port-card-img {
        transform: scale(1.08) rotate(1deg);
    }

    /* Resmin karta yumuşakça erimesi (Gradient Overlay) */
    .port-card-img-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(23, 28, 40, 0.95) 0%, transparent 70%);
        z-index: 1;
    }

    .port-card-body {
        padding: 30px;
        display: flex;
        flex-direction: column;
        flex: 1;
        position: relative;
        z-index: 2;
        /* Yazıları resmin üzerine bindirir */
        transform: translateZ(30px); /* Yazıları 3D olarak en öne çıkarır */
    }

    .port-card-title {
        font-size: 1.4rem;
        font-weight: 800;
        color: var(--text-main);
        margin-bottom: 12px;
        text-shadow: 0 2px 10px rgba(0,0,0,0.8);
        line-height: 1.3;
    }

    .port-card-text {
        color: var(--text-muted);
        font-size: 0.95rem;
        line-height: 1.7;
        margin-bottom: 25px;
        flex: 1;
    }

    /* Butonlar */
    .port-btn-outline {
        background: rgba(255,255,255,0.02);
        color: var(--text-main) !important;
        border: 1px solid rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        padding: 14px 24px;
        border-radius: 14px;
        font-weight: 700;
        font-size: 1rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        text-decoration: none;
    }

        .port-btn-outline:hover {
            background: var(--surface-hover);
            border-color: var(--brand-primary);
            transform: translateY(-4px);
            box-shadow: 0 15px 30px -5px rgba(0, 0, 0, 0.3);
            color: #fff !important;
        }

    /* GitHub butonu özel stili */
    .port-btn-github {
        background: rgba(255, 255, 255, 0.05);
        color: var(--text-main);
        padding: 14px 18px; /* Sadece ikon sığacak kadar */
    }

        .port-btn-github:hover {
            background: #fff;
            color: #000 !important; /* Github hover'da bembeyaz olur */
            border-color: #fff;
        }

</style>

<!-- SAYFA ÜST BAŞLIĞI (PAGE HEADER) -->
<section class="port-page-header container" data-aos="fade-down" data-aos-duration="800">
    <h1 class="port-page-title">
        <i class="fa-solid fa-layer-group"></i> Projelerim
    </h1>
    <p class="port-page-subtitle">
        Fikirden ürüne dönüştürdüğüm, mimarisini kurguladığım ve geliştirmekten büyük keyif aldığım çalışmalarımın tamamı.
    </p>
</section>

<div class="port-spacer-sm"></div>

<!-- PROJELER LİSTESİ (GRID) -->
<section class="container">
    <div class="row g-4 g-xl-5">
        @{
            int delay = 100;
        }

        @if (Model != null && Model.Any())
        {
            foreach (var p in Model)
            {
                <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="@delay">
                    <!-- VanillaTilt 3D Efekti için data-tilt attributeları eklendi -->
                    <div class="port-card" data-tilt data-tilt-max="5" data-tilt-speed="400" data-tilt-glare="true" data-tilt-max-glare="0.2">

                        <div class="port-card-img-wrapper">
                            @if (!string.IsNullOrEmpty(p.CoverImageUrl))
                            {
                                <img src="@p.CoverImageUrl" class="port-card-img" alt="@p.Title" loading="lazy" />
                            }
                            else
                            {
                                <!-- Eğer resim yoksa karanlık temaya uygun şık bir varsayılan (default) resim -->
                                <img src="https://images.unsplash.com/photo-1555066931-4365d14bab8c?q=80&w=800&auto=format&fit=crop" class="port-card-img" alt="Varsayılan Proje Görseli" loading="lazy" />
                            }
                            <div class="port-card-img-overlay"></div>
                        </div>

                        <div class="port-card-body">
                            <h5 class="port-card-title">@p.Title</h5>

                            <p class="port-card-text">
                                @(p.Description?.Length > 120 ? p.Description.Substring(0, 120) + "..." : p.Description)
                            </p>

                            <!-- Butonlar Bölümü: d-flex ve gap ile kusursuz hizalandı -->
                            <div class="d-flex gap-2 mt-auto">

                                <!-- Detay Butonu (Genişliği doldurur) -->
                                <a asp-action="Detail" asp-route-id="@p.Id" class="port-btn-outline flex-grow-1">
                                    İncele <i class="fa-solid fa-arrow-up-right-from-square ms-2"></i>
                                </a>

                                <!-- GitHub Butonu (Eğer URL varsa görünür, sağda küçük kutu olarak durur) -->
                                @if (!string.IsNullOrEmpty(p.GithubUrl))
                                {
                                    <a href="@p.GithubUrl" target="_blank" class="port-btn-outline port-btn-github" title="Kaynak Kodları Gör">
                                        <i class="fa-brands fa-github fs-5"></i>
                                    </a>
                                }
                            </div>
                        </div>

                    </div>
                </div>

                delay += 100;
            }
        }
        else
        {
            <!-- EĞER HİÇ PROJE YOKSA GÖSTERİLECEK ŞIK BOŞ DURUM EKRANI -->
            <div class="col-12 text-center py-5" data-aos="fade-in">
                <div class="p-5 rounded-4" style="background: rgba(23, 28, 40, 0.5); border: 1px dashed rgba(255, 255, 255, 0.2); max-width: 600px; margin: 0 auto; backdrop-filter: blur(10px);">
                    <i class="fa-solid fa-code-pull-request mb-3" style="font-size: 4rem; color: rgba(255, 255, 255, 0.7);"></i>
                    <h3 style="color: var(--text-main); font-weight: 700; margin-bottom: 10px;">Henüz Proje Eklenmemiş</h3>
                    <p class="m-0" style="color: var(--text-muted); font-size: 1.1rem; line-height: 1.6;">
                        Arka planda harika şeyler kodluyorum. Çok yakında burada yeni projeler görebilirsiniz.
                    </p>
                </div>
            </div>
        }
    </div>
</section>

<div class="port-spacer"></div>

@section Scripts {
    <!-- VanillaTilt.js Kütüphanesi (3D Kart Efekti İçin - Sadece bu sayfada yoksa diye garanti olarak ekliyoruz) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/vanilla-tilt/1.8.1/vanilla-tilt.min.js" integrity="sha512-wC/a55305TuZ600s8fFh0y8t7Hl9y0+IweaPofxRzi8A0n5qI/DxtnQ8rWlZp0R5/yH4vHhNnbkO2oHovgX1QA==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
}
