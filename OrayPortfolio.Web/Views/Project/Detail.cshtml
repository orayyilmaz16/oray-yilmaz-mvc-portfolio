@using OrayPortfolio.Domain.Entities
@model Project

@{
    ViewData["Title"] = Model.Title;
}

<style>
    /* ----- PROJE DETAY SAYFASI ÖZEL TASARIMI ----- */

    .port-spacer {
        height: 80px;
    }

    /* Geri Dönüş Linki */
    .port-back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--text-muted);
        text-decoration: none;
        font-weight: 600;
        font-size: 1rem;
        margin-bottom: 2rem;
        transition: all 0.3s ease;
    }

        .port-back-link:hover {
            color: var(--brand-secondary);
            transform: translateX(-5px);
        }

    /* Başlık Alanı */
    .port-detail-header {
        margin-bottom: 3rem;
    }

    .port-detail-title {
        font-size: clamp(2.5rem, 5vw, 4rem);
        font-weight: 800;
        color: var(--text-main);
        letter-spacing: -1.5px;
        margin-bottom: 1rem;
        line-height: 1.2;
    }

    .port-detail-subtitle {
        font-size: clamp(1.1rem, 2vw, 1.25rem);
        color: var(--text-muted);
        max-width: 800px;
        line-height: 1.7;
    }

    /* Kapak Görseli */
    .port-detail-img-wrapper {
        position: relative;
        width: 100%;
        max-height: 500px; /* Görselin çok devasa olmasını engeller */
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.3);
        border: 1px solid rgba(255, 255, 255, 0.05);
        margin-bottom: 4rem;
    }

    .port-detail-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center; /* Resmi ortalar */
    }

    /* İçerik Kartı (Glassmorphism) */
    .port-detail-content-card {
        background: rgba(23, 28, 40, 0.6);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 24px;
        padding: clamp(30px, 5vw, 50px);
        position: relative;
    }

    /* Teknoloji Etiketleri */
    .port-tech-container {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 2.5rem;
        padding-bottom: 2.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .port-tech-badge {
        background: rgba(109, 94, 249, 0.1);
        color: var(--brand-secondary);
        border: 1px solid rgba(45, 212, 191, 0.2);
        padding: 8px 18px;
        border-radius: 12px;
        font-size: 0.95rem;
        font-weight: 600;
        font-family: 'JetBrains Mono', monospace; /* Yazılımcı hissi veren font */
        letter-spacing: 0.5px;
    }

    /* Açıklama Metni */
    .port-detail-desc {
        color: var(--text-main);
        font-size: 1.15rem;
        line-height: 1.9;
        margin-bottom: 3rem;
        font-weight: 400;
    }

    /* --- Butonlar --- */
    .port-btn-group {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
    }

    .port-btn-primary, .port-btn-outline {
        padding: 16px 32px;
        border-radius: 14px;
        font-weight: 700;
        font-size: 1.05rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        text-decoration: none;
    }

    .port-btn-primary {
        background: linear-gradient(135deg, var(--brand-primary), #8b7bff);
        color: #fff !important;
        border: none;
    }

        .port-btn-primary:hover {
            transform: translateY(-4px);
            box-shadow: 0 15px 30px -5px rgba(109, 94, 249, 0.5);
        }

    .port-btn-outline {
        background: rgba(255,255,255,0.02);
        color: var(--text-main) !important;
        border: 1px solid rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
    }

        .port-btn-outline:hover {
            background: var(--surface-hover);
            border-color: var(--brand-primary);
            transform: translateY(-4px);
            box-shadow: 0 15px 30px -5px rgba(0, 0, 0, 0.3);
        }
</style>

<div class="port-spacer"></div>

<section class="container">
    <div class="row">
        <div class="col-lg-10 mx-auto">

            <!-- Geri Dönüş Linki -->
            <div data-aos="fade-right" data-aos-duration="600">
                <a asp-action="Index" class="port-back-link">
                    <i class="fa-solid fa-arrow-left"></i> Tüm Projelere Dön
                </a>
            </div>

            <!-- Sayfa Başlığı -->
            <div class="port-detail-header" data-aos="fade-up" data-aos-delay="100">
                <h1 class="port-detail-title">@Model.Title</h1>
                <p class="port-detail-subtitle">Projenin mimarisi, kullanılan teknolojiler ve canlı bağlantılar.</p>
            </div>

            <!-- Kapak Görseli -->
            @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
            {
                <div class="port-detail-img-wrapper" data-aos="zoom-in" data-aos-delay="200">
                    <img src="@Model.CoverImageUrl" class="port-detail-img" alt="@Model.Title" />
                </div>
            }

            <!-- İçerik Kartı -->
            <div class="port-detail-content-card shadow-lg" data-aos="fade-up" data-aos-delay="300">

                <!-- Kullanılan Teknolojiler -->
                @if (!string.IsNullOrEmpty(Model.Technologies))
                {
                    <h5 style="color: var(--text-muted); font-size: 1rem; margin-bottom: 15px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;">
                        Kullanılan Teknolojiler
                    </h5>

                    <div class="port-tech-container">
                        @{
                            var techs = Model.Technologies.Split(',', StringSplitOptions.RemoveEmptyEntries);
                        }
                        @foreach (var tech in techs)
                        {
                            <span class="port-tech-badge">@tech.Trim()</span>
                        }
                    </div>
                }

                <!-- Proje Açıklaması -->
                <div class="port-detail-desc">
                    <!-- Satır sonlarını (enter) HTML'de <br> olarak göstermek için Html.Raw ve Replace kullanıyoruz -->
                    @Html.Raw(Model.Description.Replace("\n", "<br/>"))
                </div>

                <!-- Aksiyon Butonları (Linkler) -->
                <div class="port-btn-group">

                    @if (!string.IsNullOrEmpty(Model.ProjectUrl))
                    {
                        <a href="@Model.ProjectUrl" target="_blank" class="port-btn-primary">
                            <i class="fa-solid fa-rocket"></i> Canlı Projeyi Gör
                        </a>
                    }

                    @if (!string.IsNullOrEmpty(Model.GithubUrl))
                    {
                        <a href="@Model.GithubUrl" target="_blank" class="port-btn-outline">
                            <i class="fa-brands fa-github"></i> Kaynak Kodları (GitHub)
                        </a>
                    }

                </div>

            </div>

        </div>
    </div>
</section>

<div class="port-spacer"></div>