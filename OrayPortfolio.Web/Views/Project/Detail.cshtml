@using OrayPortfolio.Domain.Entities
@model Project

<div class="container">

    <h2 class="mb-3">@Model.Title</h2>

    <div class="card shadow-sm border-0 p-4">

        <!-- Kapak Görseli -->
        @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
        {
            <img src="~/uploads/@Model.CoverImageUrl" class="img-fluid rounded mb-4" alt="@Model.Title" />
        }

        <!-- Açıklama -->
        <p class="text-muted fs-5">@Model.Description</p>

        <!-- Teknolojiler -->
        @if (!string.IsNullOrEmpty(Model.Technologies))
        {
            <div class="mt-3">
                <h5>Kullanılan Teknolojiler</h5>
                <span class="badge bg-primary">@Model.Technologies</span>
            </div>
        }

        <!-- Linkler -->
        <div class="mt-4">

            @if (!string.IsNullOrEmpty(Model.ProjectUrl))
            {
                <a href="@Model.ProjectUrl" target="_blank" class="btn btn-primary me-2">
                    <i class="fa-solid fa-arrow-up-right-from-square"></i> Projeyi Gör
                </a>
            }

            @if (!string.IsNullOrEmpty(Model.GithubUrl))
            {
                <a href="@Model.GithubUrl" target="_blank" class="btn btn-dark me-2">
                    <i class="fa-brands fa-github"></i> GitHub
                </a>
            }

            <a asp-action="Index" class="btn btn-secondary">
                <i class="fa-solid fa-arrow-left"></i> Geri
            </a>
        </div>

        <!-- Medya Galerisi -->
        @if (Model.MediaFiles != null && Model.MediaFiles.Any())
        {
            <hr class="my-4" />

            <h4>Proje Medyaları</h4>

            <div class="row mt-3">
                @foreach (var media in Model.MediaFiles)
                {
                    <div class="col-md-4 mb-3">
                        <div class="card shadow-sm border-0">
                            @if (media.FileType == "image")
                            {
                                <img src="@media.FilePath" class="img-fluid rounded" />
                            }
                            else
                            {
                                <a href="@media.FilePath" target="_blank" class="btn btn-outline-primary w-100">
                                    Dosyayı Aç
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>
        }

    </div>

</div>
