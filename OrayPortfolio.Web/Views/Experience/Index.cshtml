@using OrayPortfolio.Domain.Entities
@model IEnumerable<Experience>

<h2 class="mb-4">Deneyimler</h2>

<div class="timeline">

    @foreach (var e in Model)
    {
        <div class="timeline-item" data-aos="fade-up">

            <div class="timeline-dot"></div>

            <div class="timeline-content shadow-sm p-4 rounded">

                <!-- Pozisyon + Şirket -->
                <h4>@e.Position</h4>
                <p class="text-muted mb-1">@e.Company</p>

                <!-- Tarih -->
                <small class="text-muted">
                    @e.StartDate?.ToString("dd MMM yyyy") →
                    @(e.IsCurrent ? "Devam Ediyor" : e.EndDate?.ToString("dd MMM yyyy"))
                </small>

                <!-- Açıklama -->
                <p class="mt-3">@e.Description</p>

                <!-- 📌 Yeni Medya Sistemi: Tek Görsel -->
                @if (!string.IsNullOrEmpty(e.LogoImageUrl))
                {
                    <div class="mt-3">
                        <h6>Görsel</h6>
                        <img src="@e.LogoImageUrl" class="img-fluid rounded shadow-sm" style="max-width: 300px;" />
                    </div>
                }

            </div>

        </div>
    }

</div>

<!-- Timeline CSS -->
<style>
    .timeline {
        position: relative;
        margin-left: 25px;
        padding-left: 20px;
    }

        .timeline::before {
            content: "";
            position: absolute;
            left: 8px;
            top: 0;
            width: 3px;
            height: 100%;
            background: #dee2e6;
        }

    .timeline-item {
        position: relative;
        margin-bottom: 40px;
    }

    .timeline-dot {
        position: absolute;
        left: -2px;
        width: 15px;
        height: 15px;
        background: #0d6efd;
        border-radius: 50%;
        top: 5px;
    }

    .timeline-content {
        margin-left: 25px;
        background: #fff;
    }
</style>
